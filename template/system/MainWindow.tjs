    //------------------------------------------------------ Special Timer --



    /**

     * Screen update processing

     */

	function onFlipTimerInterval(now) {

		var work = false;



		// Tag expansion

		// Perform this first as it may generate actions or movies

		work = true if updateDelay(now);

		

		// Action update

		work = true if updateAction(now);



		// GenericFlip update

		if (updateGenericFlips(now)) work = true;



		// Transition layer update

		if (_transLayer !== void) {

			_transLayer.update(now);

			work = true if _transLayer.working;

		}



