		storeClickGlyphState("line");

		if(autoMode) {
			return waitAuto(autoModeLineWait, "l", hasCurrentVoice && elm.voicewait);
		}

		if(!current.nodeVisible && textWriteEnabled)
		{
			if (!callHook("onInvisibleMessageBreak", "line"))
			dm("Warning: Reached line click wait in hidden " +
				(currentPage ? "back" : "fore") + " message layer " + currentNum);
		}

		// Conductor waits for 'click'
		conductor.wait(%[
			click : function
			{
				clickWaiting = false;
				notifyRun();
                hideClickGlyphs();
            } incontextof this
			]);
		clickWaiting = true;
		notifyStable();
		return -2;
	}

	function showPageBreak(elm)
	{
