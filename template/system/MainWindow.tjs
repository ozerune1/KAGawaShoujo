			with (tempLayer) {

				.type = ltAlpha;

				.face = dfAuto;

			}

			return tempLayer;

		}

	}



	//------------------------------------------ Full-screen / Zoom Processing --



	// Get full-screen/zoom state at startup

	function getInitialFullScreenState  { return scflags.fullScreen; }

