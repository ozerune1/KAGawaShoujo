	er : function(elm)
	{
		callHook("onEraceMessage", elm);
		if (!skipNoDisp) {
			// Clear current message layer
			if(historyWriteEnabled) historyLayer.repage();
			if(currentWithBack) current.comp.clear(elm.all);
			current.clear(elm.all);
		}
		return 0;
