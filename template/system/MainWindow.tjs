	s : function(elm)
	{
        // Stop execution
		stablePosibility = true;
		cancelSkip();
		if(!usingExtraConductor) incRecordLabel(true);
		inSleep = true;
		if(recordHistoryOfStore == 2) // 2: Every choice (@s tag)
			setToRecordHistory();
		notifyStable();

        // Start message layer timeout call
        current.startTimeout();

        return -1;
	} incontextof this,

