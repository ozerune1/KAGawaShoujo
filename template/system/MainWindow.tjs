			panelLayer = void;

			panelModal = panelShowing = false;

        }

	}



	//-------------------------------------------------------------- process --



	function process(file, label, countpage = true, immediate = false)

	{

		forEachEventHook('onProcess',,usingExtraConductor);



		// Start execution from specified file and label

        if(!usingExtraConductor) {

            incRecordLabel(countpage);

			autoLabelStore.clear() if (autoLabelStore !== void && file != "");

        }

		setUserSpeed();



		if(file != '')

		{

			if (!usingExtraConductor) {

				clearVoiceMap();

			}

			// Load file

            conductor.loadScenario(file);

		}



		if(label != '')

		{

			// Move to label

			conductor.goToLabel(label);

		}



		if(isFirstProcess)

		{

			storeFlags(); // Store the very first state

			isFirstProcess = false;

		}



        if (debugLevel >= tkdlSimple)

            dm("Starting processing");

		inSleep = false;

		notifyRun();

		if(conductor.status != conductor.mRun) conductor.run(immediate); // Start execution

    }



	function processGo(immediate = false)

	{

        // Start execution from the current position of the conductor

        if (debugLevel >= tkdlSimple)

            dm("Starting processing");

		inSleep = false;

		notifyRun();

		conductor.run(immediate); // Start execution

	}



	function processCall(file, label)

	{

		// Call specified file and label

		// Note that incRecordLabel(); is not called



		if(file != '')

		{

			// Load file

			conductor.loadScenario(file);

		}



		inSleep = false;

		notifyRun();

		conductor.callLabel(label); // Start execution

        if (debugLevel >= tkdlSimple)

            dm("Starting processing");

		if(conductor.status != conductor.mRun) conductor.run();

	}



	//------------------------------------------------- Conductor Events --



	function onConductorScenarioLoad(name)

	{

		prevSkipMode = void;

        // Called before the conductor loads a new scenario file.

		// name is the scenario file to be loaded.

		// If a string is returned, it will be used as the scenario instead 

		// of the file, allowing you to write a filter here.

		// Returning true results in a normal scenario file load.

		return true;

	}





	function onConductorScenarioLoaded(name)

	{

		// Conductor loaded a new scenario file

		if(!usingExtraConductor) incRecordLabel(true);

        return true;

	}



	function checkSkipToLabel(label, page) {

		if (skipMode == SKIP_LABEL) {

			if (skipToLabelStop == "" || label == skipToLabelStop) {

				cancelSkip();

				this.onSkipToLabelStop(label, page) if (typeof this.onSkipToLabelStop != "undefined");

				callHook("onSkipToLabelStop", label, page);

			}

		}

	}

	

	function onConductorLabel(label, page)

	{

		checkSkipToLabel(label, page);

        // Conductor passed a label

		if(!usingExtraConductor)

		{

            if (label !== "*autoLabelLabel") {

				if (autoLabelMode) {

					autoLabelCount++;

				}

				incRecordLabel(true);

				autoLabelCount = 1;

			}

			setRecordLabel(conductor.curStorage, label);

		}

		setUserSpeed();

		if(!usingExtraConductor)

		{

			if (label !== "*autoLabelLabel") {

				if(!(allskip || getCurrentRead()) && skipMode < SKIP_FAST)

					cancelSkip(); // Unread, so stop skip

				if (checkSkipOnNextLabel) {

					checkSkipOnNextLabel = false;

					checkSkipOnReadedLabel();

				}

				currentStorage = conductor.curStorage;

			}

			currentLabel = label;

			if (autoLabelMode) {

				autoLabelCount++;

				storeAutoLabel();

			}

		}

		if(page !== void && page !== '')

		{

			if(page[0] == '&') page = Scripts.eval((page.substring(1)));

			currentPageName = page;

		}

		if(page !== void)

		{

			pushHistoryOfStore();

			stablePosibility = false;

            if (debugLevel >= tkdlVerbose) {

				dm(conductor.curStorage + " : Label/Page : " + label + "/" + currentPageName);

            }

			if(usingExtraConductor) throw new Exception("Saveable labels cannot be written within right-click subroutines / extraConductor subroutines");

			storeFlags(), storeLabelPassed = true, setMenuAccessibleAll();

			storeLabelPassedLastStorage = conductor.curStorage;

			if(recordHistoryOfStore == 1) // 1: Per saveable label

				setToRecordHistory();



        }



		// Recollection end check

		if (isRecollection && recollectionEndLabel != "" && recollectionEndLabel == label) {

//			incRecordLabel(true) if(!usingExtraConductor); // Immediately make it read

			var end = recollectionEndStorage;

			var cur = Storages.extractStorageName(conductor.curStorage);

			endRecollection() if (end == "" || end.toLowerCase() == cur.toLowerCase());

		}

		return true;

	}



	function onConductorJump(elm)

	{

		// When conductor processes a jump tag

        closeDialog();

        if(!usingExtraConductor) incRecordLabel(elm.countpage === void || +elm.countpage);

		return true;

	}



	function onConductorCall(elm)

	{

		// When conductor processes a call tag

		if(!usingExtraConductor) incRecordLabel(elm.countpage !== void && +elm.countpage);

		return true;

	}



	function onConductorReturn(elm)

	{

		// When conductor processes a return tag

		if(!usingExtraConductor) incRecordLabel(elm.countpage === void || +elm.countpage);

		if(conductor === extraConductor)

		{

			// Called from conductor for extraConductor subroutines

			if(conductor.callStackDepth == 1)

			{

				// This means the final return was executed

				dm("Returning from extraConductor subroutine...");

				var run;

				if(elm.storage !== void || elm.target !== void) run = true; else run = false;

				returnExtraConductor(run);

				if(elm.storage !== void) conductor.loadScenario(elm.storage);

				if(elm.target !== void) conductor.goToLabel(elm.target);

				setRecordLabel(currentStorage = conductor.curStorage, currentLabel = conductor.curLabel);

				if(run)

				{

					notifyRun();

					conductor.run();

				}

				isLeavePeriodEvent = false;

				if(elm.storage !== void || elm.target !== void)

				{	// Clear period events when returning to a location other than the original with return.

					holdPeriodEventQueue.clear();

					isWaitPeriodEvent = false;

				}

				if( isWaitPeriodEvent == true )

				{	// Trigger only when waiting for period event with [wp]

					fireMoviePeriodFromQueue();

				}

				return false; // return is not executed

			}

		}

		return true;

	}

	function purgeMoviePeriod()

	{

		isLeavePeriodEvent = false;

		holdPeriodEventQueue.clear();

		isWaitPeriodEvent = false;

		waitedPeriodEventStorageName = void;

	}

	function fireMoviePeriodFromQueue()

	{

		var retVal = false;

		if( holdPeriodEventQueue.count > 0 )

		{

			if( waitedPeriodEventStorageName == conductor.curStorage && conductor == mainConductor )

			{

				for( var i = 0; i < holdPeriodEventQueue.count; i++ )

				{

					conductor.trigger( holdPeriodEventQueue[i] );

					retVal = true;

				}

			}

			holdPeriodEventQueue.clear();

		}

		return retVal;

	}



	function onConductorAfterReturn()

	{

		// After conductor executes a return tag

		if(!usingExtraConductor)

		{

			setRecordLabel(currentStorage = conductor.curStorage, currentLabel = conductor.curLabel);

		}

		setUserSpeed();

		if(!usingExtraConductor)

		{

            if(!(allskip || getCurrentRead()) && skipMode < SKIP_FAST)

                cancelSkip(); // Unread, so stop skip

		}

    }



	function onConductorScript(script, scriptname, lineofs)

	{

		// iscript tag

		try

		{

			Scripts.exec(script, scriptname, lineofs);

		}

		catch(e)

		{

			throw new Exception("Error in iscript block starting from line " + lineofs + " of " + scriptname + "."

				"\n( Refer to the console for details )\n" + e.message);

		}

		return true;

	}

	

	// Call method for all plugin objects and abort at the first one that returns a value

	function forEachFunctionHook(method, args*) {

		var ret;

		var count = kagPlugins.count;

		for (var i =0; i<count; i++) {

			var obj = kagPlugins[i];

			if (typeof obj[method] != "undefined") {

				if ((ret = obj[method](args*)) !== void) {

					break;

				}

			}

		}

		return ret;

	}

	

	function onConductorUnknownTag(tagname, elm)

	{

		var ret = forEachFunctionHook("onUnknown", tagname, elm);

		if (ret === void) {

			@if (KAG_UNKNOWNTAG_EXCEPTION)

			throw new Exception("Tag/macro \"" + tagname + "\" does not exist");

			@endif

			errorCmd("Unknown command: " + tagname);

			return 0;

		} else {

			return ret; // This return value is the same as what each tag handler returns

		}

	}



	//----------------------------------------------------------- stable/run --



	function notifyStable()

	{

		// Call handlers when system becomes stable (waiting for click/stopped)

		if(!inStable)

		{

			inStable = true;

			var handlers = stableHandlers;

			for(var i = handlers.count-1; i>=0; i--)

				handlers[i]();



			// stableHook

			forEachEventHook('onStableStateChanged',,true);

        }

	}



	function notifyRun()

	{

		// Call handlers when system starts running

		if(inStable)

		{

			inStable = false;

			var handlers = runHandlers;

			for(var i = handlers.count-1; i>=0; i--)

				handlers[i]();



			// runHook

            forEachEventHook('onStableStateChanged',,false);

            

			if(autoMode) hideMouseCursor();

		}

	}



	function defaultStableHandler()

	{

		// Default stable handler

		setMenuAccessibleAll();

	}



	function defaultRunHandler()

	{

		// Default run handler

		hideHistory();

		hideClickGlyphs();

		showMessageLayerByUser();

		setMenuAccessibleAll();

	}



	//----------------------------------------------------------- String Input --



	var inputTemp;

	function inputString(elm)

	{

		// Input a string

		var name = elm.name;

		var initial = Scripts.eval(name);

		var res = System.inputString(elm.title, elm.prompt, initial);

		if(res !== void)

		{

			// Assign res to name

			inputTemp = res;

			Scripts.eval(("(" + name + ") = kag.inputTemp"));

		}

	}

	//-------------------------------------------------- extraConductor Processing --

	function callExtraConductor(storage, label, onreturn)
	{
		isLeavePeriodEvent = true; // Fire movie period event upon return

		// Call subroutine using extraConductor
		onExtraConductorReturn = onreturn;
		inSleepBeforeExtraConductor = inSleep; // Save inSleep state

		storeMessageLayerSelProcessLock(); // Call storeSelProcessLock for message layers
		lockSelectLayerFocus(true);

		conductor = extraConductor; // Switch conductor
		(Dictionary.assign incontextof extraConductor.macros)(mainConductor.macros);
			// Copy macros
		usingExtraConductor = true;
		if(storage == '')
		{
			// If no storage specified, load current storage
			storage = mainConductor.curStorage;
		}

		// Call
		conductor.clearCallStack();
		processCall(storage, label);
	}

	function returnExtraConductor(run)
	{
		// Return from extraConductor subroutine
		// If run is true, do not restore waiting state

		conductor.sleep(); // Stop
		conductor.interrupt();
			// interrupt is a method to stop conductor execution 
			// from within a conductor event
		conductor = mainConductor; // Switch back to main conductor
		(Dictionary.assign incontextof mainConductor.macros)(extraConductor.macros);
			// Copy macros
		usingExtraConductor = false;
		if(!run)
		{	restoreClickGlyphState(); // Restore click waiting symbol
			inSleep = inSleepBeforeExtraConductor; // Restore inSleep
			notifyStable();
		}

		lockSelectLayerFocus(false);
		restoreMessageLayerSelProcessLock(); // Call restoreSelProcessLock for message layers

		setMenuAccessibleAll();
		cancelSkip();

		if(onExtraConductorReturn !== void) onExtraConductorReturn();
	}

	// Lock/Unlock selection focus
	function lockSelectLayerFocus(lock) {
		var sel = lock ? "lockFocus" : "unlockFocus";
		selectLayer   [sel]() if (_selectLayer    !== void);
		mapSelectLayer[sel]() if (_mapSelectLayer !== void);
	}

	//------------------------------------------------------- Right Click Processing --

	function setRightClickOptions(elm)
	{
		// Set right click options
		rightClickEnabled = +elm.enabled if elm.enabled !== void;
		if(elm.call !== void)
		{
			rightClickCall = +elm.call;
			if(rightClickCall) rightClickJump = false;
		}
		if(elm.jump !== void)
		{
			rightClickJump = +elm.jump;
			if(rightClickJump) rightClickCall = false;
		}
		rightClickTarget = elm.target if elm.target !== void;
		rightClickStorage = elm.storage if elm.storage !== void;
		if(elm.name !== void)
		{
			if(typeof this.rightClickMenuItem != "undefined")
			{
				rightClickName = elm.name;
				if(rightClickName == "default")
					rightClickMenuItem.caption = rightClickCurrentMenuName = rightClickDefaultName;
				else
					rightClickMenuItem.caption = rightClickCurrentMenuName = rightClickName;
			}
		}
	}

	function callRightClickSubRoutine()
	{
		isLeavePeriodEvent = true;

		// Call right click subroutine
		if(typeof this.rightClickMenuItem != "undefined")
		{
			rightClickMenuItem.caption = rightClickCurrentMenuName = rightClickDefaultName;
		}

		callExtraConductor(rightClickStorage, rightClickTarget, restoreFromRightClick);

		lockMessageLayerSelProcess(); // Lock selections
	}

	function restoreFromRightClick()
	{
		// Called when exiting right click subroutine
		if(typeof this.rightClickMenuItem != "undefined")
		{
			if(rightClickName == "default")
				rightClickMenuItem.caption = rightClickCurrentMenuName = rightClickDefaultName;
			else
				rightClickMenuItem.caption = rightClickCurrentMenuName = rightClickName;
		}
	}

	function setConductorToMain()
	{
		// Called during restore, switches conductor to main
		if(usingExtraConductor)
		{
			extraConductor.sleep();
			extraConductor.interrupt();
			conductor= mainConductor;
			usingExtraConductor = false;
		}
	}

	function jumpToRightClickTarget()
	{
		process(rightClickStorage, rightClickTarget);
	}

	function onPrimaryRightClick()
	{
		// Called when right clicked on primary layer

		// Intercept with high priority during beginskip processing
		if (prevSkipMode !== void) {
			skipMode = SKIP_CANCEL;
			conductor.trigger('click'); // Release skip wait
			callHook(rightClickHook);   // Notify hooks
			return;
		}
		if(!callHook(rightClickHook))
		{
			if(getKeyState(VK_LBUTTON))
			{
//				enterAutoMode();
				return;
			}
			// Cancel if in Auto or Skip mode
			if (conductor.status != conductor.mStop) {
				// Refer to onPrimaryClick for conditions
				if (canCancelSkipByClick && skipMode && skipMode < SKIP_FAST) return cancelSkip();
				if (autoMode) return cancelAutoMode();
			}
			if(!rightClickEnabled) return;
			if(inStable)
			{
				if(rightClickJump)
					jumpToRightClickTarget();
				else if(rightClickCall && conductor == mainConductor)
					callRightClickSubRoutine();
				else
					switchMessageLayerHiddenByUser();
			}
			setMenuAccessibleAll();
		}
	}

	//------------------------------------------------------- Foreground Layer Processing --

    function allocateCharacterLayers(num, reorder=true, level=0)
	{
		// Set foreground layer count to num
		if(fore.layers.count > num)
		{
			// Decrease layers
			for(var i = num; i<fore.layers.count; i++)
			{
				invalidate fore.layers[i];
				invalidate back.layers[i];
			}
			fore.layers.count = num;
			back.layers.count = num;
		}
		else if(fore.layers.count < num)
		{
            // Increase layers
            if (reorder) {
                for(var i = fore.layers.count; i<num; i++)
                {
                    fore.layers[i] = new CharacterLayer(this, fore.base, "Fore Foreground Layer " + i, i, level);
                    back.layers[i] = new CharacterLayer(this, back.base, "Back Foreground Layer " + i, i, level);
                    fore.layers[i].setCompLayer(back.layers[i]);
                    back.layers[i].setCompLayer(fore.layers[i]);
                }
                reorderLayers(true, false);
            } else {
                // Find maximum index value at target level
                var foreindex = (level + 1) * 100000;
                var backindex = (level + 1) * 100000;
                for (var i=0; i<fore.layers.count;i++) {
                    if (fore.layers[i].level == level && fore.layers[i].absolute > foreindex) {
                        foreindex = fore.layers[i].absolute;
                    }
                    if (back.layers[i].level == level && back.layers[i].absolute > backindex) {
                        backindex = back.layers[i].absolute;
                    }
                }
                foreindex += 100;
                backindex += 100;
                
                for(var i = fore.layers.count; i<num; i++) {
                    fore.layers[i] = new CharacterLayer(this, fore.base, "Fore Foreground Layer " + i, i, level);
                    back.layers[i] = new CharacterLayer(this, back.base, "Back Foreground Layer " + i, i, level);
                    fore.layers[i].setCompLayer(back.layers[i]);
                    back.layers[i].setCompLayer(fore.layers[i]);
                    fore.layers[i].absolute = foreindex;
                    back.layers[i].absolute = backindex;
                    foreindex += 100;
                    backindex += 100;
                }
            }
        }
		numCharacterLayers = num;
	}

	//------------------------------------------------- Message Layer Processing --

	function allocateMessageLayers(num, setdefaultfont = true)
	{
		// Set message layer count to num
		if(fore.messages.count > num)
		{
			// Decrease layers
			for(var i = num; i<fore.messages.count; i++)
			{
				if(current == fore.messages[i] || current == back.messages[i])
					current = fore.messages[0], currentNum = 0, currentPage = 0;
				invalidate fore.messages[i];
				invalidate back.messages[i];
			}
			fore.messages.count = num;
			back.messages.count = num;
		}
		else if(fore.messages.count < num)
		{
			// Increase layers
			for(var i = fore.messages.count; i<num; i++)
			{
				fore.messages[i] = new MessageLayer(this, fore.base, "Fore Message Layer " + i, i, true);
				back.messages[i] = new MessageLayer(this, back.base, "Back Message Layer " + i, i, true);
				fore.messages[i].setCompLayer(back.messages[i]);
				back.messages[i].setCompLayer(fore.messages[i]);
				fore.messages[i].clear();
				back.messages[i].clear();
			}
			reorderLayers(false, true);
			if(setdefaultfont) setMessageLayerUserFont();
		}
		numMessageLayers = num;
	}

	function setCurrentMessageLayer(elm)
	{
		// Set current message layer
		var page = getMessageLayerPageFromElm(elm);
		var num = getMessageLayerNumberFromElm(elm);
		currentNum = num;
		currentPage = page;
		if(page) current = back.messages[num]; else current = fore.messages[num];
		currentWithBack = +elm.withback if elm.withback !== void;
	}

	function setMessageLayerPosition(elm)
	{
		// Set current message layer position and attributes
		var layer = getMessageLayerObjectFromElm(elm);
		elm.setPosition(elm);
	}

	function clearMessageLayers(resetcurrent)
	{
		// Clear all message layers
		// Called from ct tag
		// If resetcurrent is true, set current message layer to Fore 0

		var messages;
		messages = fore.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].clear(true);
		messages = back.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].clear(true);
		if(resetcurrent)
		{
			currentNum = 0;
			currentPage = 0;
			current = fore.messages[0];
			currentWithBack = false;
		}
	}

	function lockMessageLayerSelProcess()
	{
		// Disable selection and process for all message layers
		var messages;
		messages = fore.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].setSelProcessLock(true);
		messages = back.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].setSelProcessLock(true);

		invokeSelectLayerSetSelProcessLock(true);
	}

	function unlockMessageLayerSelProcess()
	{
		// Enable selection for all message layers
		var messages;
		messages = fore.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].setSelProcessLock(false);
		messages = back.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].setSelProcessLock(false);

		invokeSelectLayerSetSelProcessLock(false);
	}

	function setMessageLayerUserFont()
	{
		// Set defaultAntialiased and userFace for all message layers
		var messages;
		messages = fore.messages;
		for(var i = messages.count-1; i >= 0; i--)
			messages[i].defaultAntialiased = chDefaultAntialiased,
			messages[i].userFace = chDefaultFace,
			messages[i].resetNameLayerFont();
		messages = back.messages;
		for(var i = messages.count-1; i >= 0; i--)
			messages[i].defaultAntialiased = chDefaultAntialiased,
			messages[i].userFace = chDefaultFace,
			messages[i].resetNameLayerFont();
		if (typeof historyLayer.fontUpdate == "Object") {
			/**/   historyLayer.fontUpdate(historyShowing);
		}
		if (chBitmapFont != "") {
			if (bitmapFont == null ||  bitmapFont.name != chBitmapFont) {
				try {
					bitmapFont = new BitmapFont(this);
					bitmapFont.load(chBitmapFont);
				} catch(e) {
					dm("Failed to load bitmap font: " + chBitmapFont, e.message);
					chBitmapFont = "";
					bitmapFont = null;
				}
			}
		} else {
			bitmapFont = null;
		}
		callHook("onSetMessageLayerUserFont", chDefaultFace);
	}

	function storeMessageLayerSelProcessLock()
	{
		// Call storeSelProcessLock for all message layers
		var messages;
		messages = fore.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].storeSelProcessLock();
		messages = back.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].storeSelProcessLock();
	}

	function restoreMessageLayerSelProcessLock()
	{
		// Call restoreSelProcessLock for all message layers
		var messages;
		messages = fore.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].restoreSelProcessLock();
		messages = back.messages;
		for(var i = messages.count-1; i >= 0; i--) messages[i].restoreSelProcessLock();
	}

	function setMessageLayerHiddenState(b, page)
	{
		var layers, base = !page ? fore : back;
		layers = base.messages;
		for(var i = layers.count-1; i >= 0; i--) layers[i].setHiddenStateByUser(b);
		layers = base.layers;
		for(var i = layers.count-1; i >= 0; i--) layers[i].setHiddenStateByUser(b);

		selectLayer.setHiddenStateByUser(b);
		//mapSelectLayer.setHiddenStateByUser(b);

		// Call plugins
		forEachEventHook('onMessageHiddenStateChanged',,b, page);
	}

    // Synchronize message layer state
    function syncMessageLayer() {
        var messages = back.messages;
        for(var i = messages.count-1; i >= 0; i--) messages[i].assignComp();
    }
    
	function hideMessageLayerByUser()
	{
        // Temporarily hide message layers
		if(messageLayerHiding) return;
		setMessageLayerHiddenState(true);
		if(typeof this.rightClickMenuItem !== "undefined")
			rightClickMenuItem.checked = true;
		messageLayerHiding = true;
		fore.base.cursor = cursorWaitingClick;
		setMenuAccessibleAll();
	}

	function showMessageLayerByUser()
	{
        // Restore temporarily hidden message layers
		if(!messageLayerHiding) return;
        setMessageLayerHiddenState(false);
		if(typeof this.rightClickMenuItem !== "undefined")
			rightClickMenuItem.checked = false;
		messageLayerHiding = false;
		conductor.trigger('message'); // Send 'message' trigger
		clickWaiting = _clickWaiting; // Reset mouse cursor
		setMenuAccessibleAll();
	}

	function switchMessageLayerHiddenByUser()
	{
		// Toggle message layer visibility
		if(messageLayerHiding) showMessageLayerByUser(); else hideMessageLayerByUser();
	}

	function hideMessageLayerByScenario(elm)
	{
		// Temporarily hide message via scenario
		hideMessageLayerByUser();
		conductor.wait(%[ // Set conductor to wait
			message : function
			{
				// No action
			} incontextof this
			]);
        notifyStable();
		return -2; // break
	}

    function setCurrentMessageLayerVisibleFast(page, visible) {
		var base = page == 0 ? fore : back;
		var msg = base.messages[currentNum];
		msg.visible = visible;
		forEachEventHook('onCurrentMessageVisibleChanged',
						 function(handler, f) { handler(f.hidden, f.page, 0); } incontextof this,
						 %[hidden:!visible, page:page]);
    }

    /**
     * Change visibility state of current message window
     * @param visible
     * @return returns true if a wait is required
	 */
    function setCurrentMessageLayerVisible(visible, time) {
		
		if (fore.messages[currentNum].visible != visible) {
			var fadeTime = (time !== void ? +time : messageFadeTime) * effectspeed;
			if (fadeTime > 0) {
				
				// Hide back layer first to avoid msgvisible triggering early and clearing wait
                back.messages[currentNum].visible = visible;
                
                // Wait for processing
                var layer = fore.messages[currentNum];
                layer.setVisibleTime(visible, fadeTime);

				conductor.wait(%[
				click : function(layer) {
					updateBeforeCh = 1;
					layer.fadeDone();
				} incontextof this,
					'click_arg' => layer,
				msgvisible : function() {
					updateBeforeCh = 1;
				} incontextof this
					]);
				forEachEventHook('onCurrentMessageVisibleChanged',
								 function(handler, f) { handler(f.hidden, f.page, f.time); } incontextof this,
								 %[hidden:!visible, page:0, time:fadeTime ]);
				return true;
            } else {
				fore.messages[currentNum].visible = visible;
				back.messages[currentNum].visible = visible;
				forEachEventHook('onCurrentMessageVisibleChanged',
								 function(handler, f) { handler(f.hidden, f.page, 0); } incontextof this,
								 %[hidden:!visible, page:0]);
			}
        }
        return false;
    }

	// ----------------------------------------------------------------------------
	// Special interface for message windows
	// ----------------------------------------------------------------------------

	// Simple name clear
	function clearName() {
		currentVoice.clear() if (currentVoice !== void);
		if (textWriteEnabled) {
			current.processName();
			if(currentWithBack) current.comp.processName();
		}
	}
	
	// Name drawing process. Also registered to history
	function drawName(name, nextVoice) {
		//dm("Voice state updated!:" + name + ":" + nextVoice);
		currentVoice = [] if (currentVoice === void);
		currentVoice.assign(nextVoice) if (nextVoice !== void);
		if (textWriteEnabled) {
			current.processName(name);
			if(currentWithBack) current.comp.processName(name);
		}
		// For history
		if (historyWriteEnabled) {
			if (typeof historyLayer.storeName !== 'undefined') {
				historyLayer.storeName(name);
			} else {
				if (name != "") {
					historyLayer.store(name + " ");
				}
			}
		}
		callHook("onDrawName", name);
	}

	/**
	 * Subcontractor for face display processing
	 */
	function loadFaceLayer(layer, name) {
		try {
			layer.loadImages(name);
		} catch (e) {
			errorImage(name + ": Face image could not be loaded");
		}
		layer.visible = true;
	}

    /**
     * Subcontractor for face clearing processing
	 */
	function clearFaceLayer(layer, clearImage, callback = true) {
		if (layer === void) return;
		if (clearImage !== void) {
			loadFaceLayer(layer, clearImage);
		} else {
			with (layer) {
				.fillRect(0,0,.width,.height,0);
				.visible = true;
			}
		}
		if (callback && typeof layer.onFaceCleared == "Object") layer.onFaceCleared();
    }

	/**
	 * Draw to face layer
	 * @param layer destination
	 * @param image image drawing function or the image itself
	 * @return true if drawn
	 */
	function drawFaceLayer(layer, image, clearImage) {
		if (layer === void) return;
		var r = false;
		if (typeof image == "Object") {
			layer.visible = true;
			if (image(layer)) r = true;
		} else if (image !== void) {
			loadFaceLayer(layer, image);
			r = true;
		}
		if (!r) clearFaceLayer(layer, clearImage, false);
		if (typeof layer.onFaceDrawed == "Object") layer.onFaceDrawed(r);
		return r;
	}
	
	/**
	 * Clear face
	 * @param time clearing duration
	 * @param clearImage image to use for clear
	 * @param page page specification (0:fore, 1:back, current if omitted)
	 */
	function clearFace(time, clearImage, page = void) {
		var layer;
		if (page === void) layer = current.faceLayer;
		else layer = (page == 0 ? fore : back).messages[currentNum].faceLayer;
		if (layer !== void) {
			time *= effectspeed;
			if (layer.visible && time > 0) {
				layer.stopTransition(); // Might swap fore/back as side effect
				var fore = layer = current.faceLayer;
				var back =         current.comp.faceLayer;
				if (fore !== void && back !== void) {
					if (fore.visible) {
						clearFaceLayer(back, clearImage);
						fore.syncSize(back);
						fore.beginTransition(%[method: "crossfade", time:time], back);
					}
				}
			} else {
				clearFaceLayer(layer, clearImage);
			}
		}
	}

	/**
	 * Draw face
	 * @param image drawing function or image filename
	 * @param time display duration
	 * @param clearImage image to use for clear
	 */
	function drawFace(image, time, clearImage) {
		var layer = current.faceLayer;
		if (layer !== void) {
			layer.stopTransition(); // Might swap fore/back as side effect
			var fore = current.faceLayer;
			var back = current.comp.faceLayer;
			var hasImage;
			time *= effectspeed;
			if (time > 0) {
				if (fore !== void && back !== void) {
					if (!fore.visible) {
						// Ensure it is visible if not already
						fore.fillRect(0,0,fore.width,fore.height,0);
						fore.visible = true;
					}
					hasImage = drawFaceLayer(back, image, clearImage);
					fore.syncSize(back);
					fore.beginTransition(%[method: "crossfade", time:time ], back);
				}
			} else {
				hasImage = drawFaceLayer(fore, image, clearImage);
				back.assignImages(fore, true);
			}
		}
	}

	// ----------------------------------------------------------------------------
	
	property genericFontInstance { getter { return fore.base.font; } }
	function getFontFaceList() {
		return genericFontInstance.getList(...);
	}
	function selectFontDoUserSelect() {
		// Select font
		with (genericFontInstance) {
			.face = chDefaultFace;
			.height = -20;
			if (.doUserSelect(...)) return .face;
		}
	}
	function selectFont()
	{
		var flags = fsfSameCharSet | fsfNoVertical | fsfTrueTypeOnly | fsfUseFontFace;
		if(showFixedPitchOnlyInFontSelector) flags |= fsfFixedPitch;
		var sample = typeof this.selectFontSampleText == "String" ? selectFontSampleText : "ABCDEFGHI abcdefghi";
		var sel = selectFontDoUserSelect(flags, "Font Selection", "Please select a font", sample);
		if (sel != "")
		{
			chBitmapFont  = "";
			chDefaultFace = sel;
			setMessageLayerUserFont();
		}
		callHook("onSetBitmapFontHook", chBitmapFont);
	}

	function setBitmapFont(name)
	{
		chBitmapFont  = name;
		chDefaultFace = "MS Gothic"; // XXX
		setMessageLayerUserFont();
		saveSystemVariables();
		callHook("onSetBitmapFontHook", chBitmapFont);
	}

	function mapPrerenderedFont(storage)
	{
		// Map pre-rendered font to font selected in current target layer
		current.decideSizeChange();
		current.lineLayer.font.mapPrerenderedFont(storage);
	}

    //------------------------------------------------- Put layers in correct order --

    // Move specified layer to specified level
    function toLevel(n, newlevel, base) {
        if (base === void) {
            base = fore;
        }
        if (n === void) {
            return;
        }
        n = +n;
        newlevel = +newlevel;
        if (n < base.layers.count) {
            
            var level = base.layers[n].level;
            if (level == newlevel) {
                return;
            }
            var index = base.layers[n].absolute;
            // Adjust current level
            for (var i = 0; i<base.layers.count; i++) {
                if (i != n && base.layers[i].level == level) {
                    if (base.layers[i].absolute > index) {
                        base.layers[i].absolute -= 100;
                    }
                }
            }
            // Move to top of new level
            var newindex = (newlevel + 1) * 100000;
            for (var i = 0; i<base.layers.count; i++) {
                if (i != n && base.layers[i].level == newlevel && base.layers[i].absolute > newindex) {
                    newindex = base.layers[i].absolute;
                }
            }
            newindex += 100;
            //dm("Level set:" + newlevel + ":" + newindex);
            base.layers[n].absolute = newindex;
            base.layers[n].level = newlevel;
        }
    }
    
    // Move to front among layers of the same level
    function toFront(n, base) {
        if (base === void) {
            base = fore;
        }
        if (n !== void && n < base.layers.count) {
            var level = base.layers[n].level;
            var index = base.layers[n].absolute;
            var maxindex = index;
            for(var i = 0; i<base.layers.count; i++) {
                if (i != n && base.layers[i].level == level) {
                    if (base.layers[i].absolute > maxindex) {
                        maxindex = base.layers[i].absolute;
                    }
                    if (base.layers[i].absolute > index) {
                        base.layers[i].absolute -= 100;
                    }
                }
            }
            base.layers[n].absolute = maxindex;
        }
    }

    // Move layer to back
    function toBack(n, base) {
        if (base === void) {
            base = fore;
        }
        if (n !== void && n < base.layers.count) {
            var level = base.layers[n].level;
            var index = base.layers[n].absolute;
            var minindex = index;
            for(var i = 0; i<base.layers.count; i++) {
                if (i != n && base.layers[i].level == level) {
                    if (base.layers[i].absolute < minindex) {
                        minindex = base.layers[i].absolute;
                    }
                    if (base.layers[i].absolute < index) {
                        base.layers[i].absolute += 100;
                    }
                }
            }
            base.layers[n].absolute = minindex;
        }
    }

    function reorderLayers(ch=true, msg=true)
	{
        // Sort layers into correct order
        if (ch) {
            var indexes = %[];
            for(var i = 0; i<fore.layers.count; i++)
            {
                var level = fore.layers[i].level;
                var index = indexes[level];
                if (index === void) {
                    index = (level + 1) * 100000;
                }
                fore.layers[i].absolute = index;
                back.layers[i].absolute = index;
                index += 100;
                indexes[level] = index;
            }
        }

        if (msg) {
            var index = 1000000;
            for(var i = 0; i<fore.messages.count; i++)
            {
                fore.messages[i].absolute = index;
                back.messages[i].absolute = index;
                index += 1000;
            }
        }

		historyLayer.absolute = historyLayerAbsolute;
	}

	//--------------------------------------------- Property -> Layer Object --

	function getLayerFromElm(elm, prefix = '')
	{
		// Returns corresponding object based on page and layer attributes in elm
		// prefix specifies prefix for attribute names
		var base;
		if(elm[prefix + 'page'] == 'back') base = back; else base = fore;
		var layer = elm[prefix + 'layer'];
		if(layer == 'base') return base.base; // Background
		if(layer[0] == 'm')
		{
			// message? ( ? = number )
			// Strict error checking omitted here
			if(layer == 'message') return base.messages[currentNum];
			return base.messages[+layer.substr(7)];
		}
		return base.layers[+layer];
	}

	function getLayerPageFromElm(elm, backlay)
	{
		// Similar to getLayerFromElm, but ignores page attribute.
		// Returns back layer if backlay is true, fore layer otherwise.
		// Returns background layer if elm.layer is void.
		var base = backlay?back:fore;
		var layer = elm.layer;
		if(layer === void || layer == 'base') return base.base; // Background
        if(layer[0] == 'm')
		{
			if(layer == 'message') return base.messages[currentNum];
			return base.messages[+layer.substr(7)];
		}
		return base.layers[+layer];
	}

	function getMessageLayerPageFromElm(elm)
	{
		// Returns 1 for back page, 0 for fore page message layer array from elm
		if(elm.page == 'back') return 1; else return 0;
	}

	function getMessageLayerNumberFromElm(elm)
	{
		// Returns message layer number indicated by layer attribute in elm
		var layer = elm.layer;
		if(layer === void || layer == 'message') return currentNum;
		return +layer.substr(7);
	}

	function getMessageLayerObjectFromElm(elm)
	{
		// Returns message layer indicated by layer attribute in elm
		var page = elm.page;
		var layer = elm.layer;
		if(page === void && layer === void) return current;
		var base;
		if(page == 'back') base = back; else base = fore;
		if(layer === void || layer == 'message') return base.messages[currentNum];
		return base.messages[+layer.substr(7)];
	}

	function getMessageLayerObjectFromPageAndNumber(page, num)
	{
		return (page?back:fore).messages[num];
	}

	//----------------------------------------------------- Layer Copy Related --

	function backupLayer(elm, toback)
	{
        // Perform copy between Fore <-> Back layers
		// toback = true for Fore -> Back, false for Back -> Fore
		if(elm.layer !== void)
		{
			// Specific layer specified
			getLayerPageFromElm(elm, toback).assignComp(); // Copy contents of paired layer
		}
		else
		{
			// No layer specified, copy all layers
			var base = toback ? back:fore;
			base.base.assignComp();
            var layers = base.layers, messages = base.messages;
			for(var i = layers.count-1; i >= 0; i--) layers[i].assignComp();
			for(var i = messages.count-1; i >= 0; i--) messages[i].assignComp();

			forEachEventHook('onCopyLayer',
				function(handler, f) { handler(f.toback, true); } incontextof this,
				%[toback:toback]);
		}
	}

	function copyLayer(elm)
	{
		// Copy between same type of layers according to elm
		var src = getLayerFromElm(elm, 'src');
		var dest = getLayerFromElm(elm, 'dest');
		dest.assign(src);
	}

	//--------------------------------------------------- Animation Related --

	function onAnimationStopped(name, segment)
	{
		// Animation stopped
		conductor.trigger('anim:' + name + ':' + segment);
	}

	function waitAnimation(elm, canskip)
	{
		// Wait for animation to stop
		var target;
		if (elm.layer !== void) {
			target = getLayerFromElm(elm);
		} else if (typeof elm.target == "Object") {
			target = elm.target;
		} else if (typeof elm.target == "String") {
			target = Scripts.eval(elm.target);
		}
		if (target !== void) {
			if (typeof target == "Object" && target instanceof "KAGLayer") {
				return waitLayerAnimation(target, elm.canskip, +elm.wait, +elm.seg);
			} else {
				dm("Animation wait must be specified on a layer");
			}
		}
		return 0;
	}

	function waitLayerAnimation(layer, canskip, wait=0, seg=0)
	{
		// Wait for animation to stop
		if(!layer.canWaitAnimStop(seg)) return 0; // Check if can wait
		//dm("Waiting for animation end 1");
		var name = 'anim:' + layer.name + ':' + seg;		
		if((canskip === void || +canskip) && clickSkipEnabled)
		{
			conductor.wait(%[
				click : function (layer)
				{
					layer.stopAnim(0); // Stop playback
				} incontextof this,
				'click_arg' => layer, // Argument to handler
				name => function(arg) {
					return arg;
				} incontextof this,
				name + "_arg" => wait,
					]);
		} else {
			conductor.wait(%[
				name => function(arg) {
					return arg;
				} incontextof this,
				name + "_arg" => wait,
					]);
		}
		return -2;
	}
	
	//--------------------------------------------------- Transition Related --

	function beginTransition(layer, elm) {
		if (layer == fore.base)  {
			if (selectShowing) {
				selectLayer.setParent(back.base, selectLayerAbsolute);
			}
			if (mapSelectShowing) {
				mapSelectLayer.setParent(back.base, mapSelectLayerAbsolute);
			}
		}
		layer.beginTransition(elm);
	}
	
	function onLayerTransitionCompleted(layer, dest, src)
	{
		// Called when transition on a layer ends
		conductor.trigger('trans_' + (string)layer);
		if (!isInAction(layer)) {
			conductor.trigger('acttrans_' + (string)layer);
		}
		if (transCount == 0) {
			// All transitions ended
			conductor.trigger('trans'); // Send 'trans' trigger
			forEachEventHook('onAllTransitionCompleted');
			if (!isWorkingAction()) {
				conductor.trigger('acttrans');
				forEachEventHook('onAllActionTransitionCompleted');
			}
			if (typeof this.transCompletedHandler == "Object") {
				transCompletedHandler();
			}
		}
    }

	/**
	 * Wait for a single layer transition
	 */
	function waitSingleTransition(target, canskip=void, wait=0) {
		if (!target.inTransition) return 0; // Cannot wait
		var name = 'trans_' + (string)target;
		if((canskip === void || +canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip operation
				target.stopTransition(true);
				return 0; // Stop move and return immediately
			}
			conductor.wait(%[
				click : function (target)
				{
                    updateBeforeCh = 1;
					if (isvalid target) {
						target.stopTransition(true); // Stop transition
					}
				} incontextof this,
				'click_arg' => target, // Argument to handler
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		else
		{
			conductor.wait(%[
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		return -2;
	}
	
	function waitAllTransition(elm)
	{
		// Wait for transitions
		if(transCount == 0) return 0; // No transitions to wait for
		if((elm.canskip === void || +elm.canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip operation
				stopAllTransitions(true);
				return 0; // Stop transitions and return immediately
			}
			conductor.wait(%[
				click : function
				{
					updateBeforeCh = 1;
					stopAllTransitions(true); // Stop all transitions
				} incontextof this,
				trans : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				trans_arg : +elm.wait
				]);
		}
		else
		{
			conductor.wait(%[
				trans : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				trans_arg : +elm.wait
				]);
		}
		return -2;
	}

	function waitTransition(elm) {
        // Wait for transition
		var target;
		if (elm.layer !== void) {
			target = getLayerFromElm(elm);
		} else if (typeof elm.target == "Object") {
			target = elm.target;
		} else if (typeof elm.target == "String") {
			target = Scripts.eval(elm.target);
		}
		if (target !== void) {
			if (isvalid target) {
				if (typeof target == "Object" && target instanceof "KAGLayer") {
					return waitSingleTransition(target, elm.canskip, +elm.wait);
				} else {
					dm("Transition wait must be specified on a layer");
				}
			}
			return 0;
		} else {
			return waitAllTransition(elm);
		}
	}
	
	function stopAllTransitions(all)
	{
		// Stop all transitions
		onLayerCommand(%[command:"stopTransition", args:[all]]);
		transCount = 0; // Just in case
	}

	function callExchangeInfo()
	{
		// Call exchangeInfo for all fore layers except background
        var layers = fore.layers, messages = fore.messages;
		for(var i = layers.count-1; i >= 0; i--) layers[i].exchangeInfo();
		for(var i = messages.count-1; i >= 0; i--) messages[i].exchangeInfo();
    }

	function callAssignTransSrc()
	{
		// Call assignTransSrc for all fore layers except background
        var layers = fore.layers, messages = fore.messages;
		for(var i = layers.count-1; i >= 0; i--) layers[i].assignTransSrc();
		for(var i = messages.count-1; i >= 0; i--) messages[i].assignTransSrc();
        forEachEventHook('onCopyLayer',,false);
    }

	function exchangeForeBack()
	{
        var tmp = fore;
		fore = back;
		back = tmp;
		current = (currentPage?back:fore).messages[currentNum]; // Re-set current
		forEachEventHook('onExchangeForeBack');

        // Restore choices
        if (selectShowing) {
            selectLayer.setParent(fore.base, selectLayerAbsolute);
        }
        if (mapSelectShowing) {
            mapSelectLayer.setParent(fore.base, mapSelectLayerAbsolute);
        }

        // Force visibility update
        fore.base.visible = true;
        back.base.visible = false;
    }

	function swapBaseLayer()
	{
        // Swap background layers only
        var tmp = fore.base;
		fore.base = back.base;
		back.base = tmp;
        current = (currentPage?back:fore).messages[currentNum]; // Re-set current

    }

	function swapStageLayer(id)
	{
        // Swap fore and back for foreground layer
        var fl = fore[id], bl = back[id];
        var tmp = fl;
        fl = bl;
        bl = tmp;
	}
    
	function swapCharacterLayer(id)
	{
		// Swap fore and back for foreground character layer
		var fl = fore.layers, bl = back.layers;
		var tmp = fl[id];
		fl[id] = bl[id];
		bl[id] = tmp;
	}

	function swapMessageLayer(id)
	{
		// Swap fore and back for message layer
		var fl = fore.messages, bl = back.messages;
		var tmp = fl[id];
		fl[id] = bl[id];
		bl[id] = tmp;
		current = (currentPage?back:fore).messages[currentNum]; // Re-set current
	}

	//--------------------------------------------------------- Auto-Move Related --

	function onLayerMoveStop()
	{
		// Layer auto-move ended
		conductor.trigger('move');
	}

	function waitMove(elm)
	{
		// Wait for auto-move
		if(moveCount == 0) return 0; // No auto-move to wait for
		if((elm.canskip === void || +elm.canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip operation
				stopAllMoves();
				return 0; // Stop auto-move and return immediately
			}
			conductor.wait(%[
				click : function
				{
					updateBeforeCh = 1;
					stopAllMoves(); // Stop all transitions
				} incontextof this,
				move : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				move_arg : +elm.wait
				]);
		}
		else
		{
			conductor.wait(%[
				move : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				move_arg : +elm.wait
				]);
		}
		return -2;
	}

	function stopAllMoves()
	{
		// Stop all auto-moves
		var layers, messages;
		fore.base.stopMove();
		back.base.stopMove();
        layers = fore.layers, messages = fore.messages;
		for(var i = layers.count-1; i >= 0; i--) layers[i].stopMove();
		for(var i = messages.count-1; i >= 0; i--) messages[i].stopMove();
		layers = back.layers, messages = back.messages;
		for(var i = layers.count-1; i >= 0; i--) layers[i].stopMove();
		for(var i = messages.count-1; i >= 0; i--) messages[i].stopMove();
		moveCount = 0; // Just in case
	}

	//--------------------------------------------------------- Action Related --

    // All action targets
    var allActions = %[];

	// Whether actions targeted by wait are running
	function isWorkingAction() {
		var names = [];
		names.assign(allActions);
		var count = 0;
		for (var i=0;i<names.count;i+=2) {
			var info = names[i+1];
			if (!info.nowait) {
				return true;
			}
		}
		return false;
	}

    /**
     * Check if action is running
     */
	function isInAction(target) {
        return allActions[target] !== void;
    }

	/**
	 * Copy action information
	 * @param src copy source
	 * @param dest copy destination
	 */
	function copyAction(src, dest, completed) {
		//dm("Copying action info");
		stopAction(dest);
		var srcAction = allActions[src];
		if (srcAction !== void) {
			var destAction = srcAction.clone();
			destAction.target = dest;
			destAction.onActionCompleted = completed if (completed !== void);
			allActions[dest] = destAction;
		}
	}

	/**
	 * Returns result of action execution
	 * @param target target object
	 */
	function getActionResult(target) {
		var info = allActions[target];
		return info !== void ? info.getResultValue() : void;
	}
	
    /**
	 * Register an action
	 * @param target target object
     * @param action action information
	 * @param elm parameter
	 * @param completed end handler
	 * @param nowait do not wait
     */
	function beginAction(target, action, completed, nowait) {
		//dm("Action start:" + target + ":" + nowait + ":" + action.nowait);
		var info = allActions[target];
		if (info === void) {
			info = new ActionSequense(target);
			allActions[target] = info;
		}
		// Register end handler
		info.onActionCompleted = completed if (completed !== void);
        
        // Evaluate if string
        if (typeof action == "String") {
            action = Scripts.eval(action);
        }
        
        if (typeof action == "Object") {
			if (action instanceof "Dictionary") {
				//dm("Dictionary action:" + action);
				//showKeys("Action", action);
				// If dictionary
				if (typeof action.module == "Object") {
					//dm("Module directly specified");
					throw new Exception("Spec change: Action name must be specified as a string:" + action.module);
				} else if (typeof action.module == "String") {
					//dm("Module name specified:" + action.module);
					var module = Scripts.eval(action.module);
					if (module !== void) {
						module(info, action);
					} else {
						throw new Exception("Action module does not exist:" + action.module);
                    }
                } else if (typeof action.moduleName == "String") {
					// If moduleName is specified, treat as action definition
					//dm("Module name specified:" + action.moduleName);
                    var module = Scripts.eval(action.moduleName);
                    if (module !== void) {
                        module(info, action);
					} else {
						throw new Exception("Action module does not exist:" + action.moduleName);
                    }
                } else {
                    // Specify multiple simultaneous actions
					info.addActions(action);
				}
                if (action.next) {
					info.next();
				}
				if (action.nowait !== void) {
					info.nowait = action.nowait;
				}
			} else if (action instanceof "Array") {
				//dm("Sequence action");
				for (var i=0;i<action.count;i++) {
					var ac = action[i];
					if (typeof ac == "Object" && ac instanceof "Dictionary") {
						if (ac.loop !== void) {
							info.addLoop(ac.loop, ac.count);
						} else if (ac.wait !== void) {
							info.addWait(+ac.wait);
						} else {
							info.addActions(ac);
							info.next();
							if (ac.nowait !== void) {
								info.nowait = ac.nowait;
							}
						}
					} else if (typeof ac == "Integer") {
						info.addWait(+ac);
					}
				}
			}
        }
		if (nowait !== void) {
			info.nowait = nowait;
		}
		flipStart();
		return info.getResultValue();
	}

	// Stop individual action
	function internalActionComplete(info, stop) {
		var target;
		with (info) try {
			target = .target;
			.stopAction() if (stop);
			.onActionCompleted(target) if (typeof .onActionCompleted == "Object");
		} catch (e) {
			Debug.message(e.message);
		}
		conductor.trigger('action_' + (string)target);
		if (isvalid target && target instanceof "GraphicLayerEx" && !target.inTransition) {
			conductor.trigger('acttrans_' + (string)target);
		}
	}
	// Stop all actions
	function internalAllActionComplete() {
		conductor.trigger('action');
		forEachEventHook('onAllActionCompleted');
		if (transCount == 0) {
			conductor.trigger('acttrans');
			forEachEventHook('onAllActionTransitionCompleted');
		}
		actionCompletedHandler() if (typeof this.actionCompletedHandler == "Object");
	}

	/**
     * Stop action
     * @param target target object
     */
	function stopAction(target) {
		if (((string)target) == "") return;
		var info = allActions[target];
		if (info !== void) {
			delete allActions[target];
			//dm("Specified action stop:" + target);
			internalActionComplete(info, true);
			invalidate info;
			if (!isWorkingAction()) {
				internalAllActionComplete();
			}
		}
	}

    /**
     * Stop all actions
	 * @param all also stop nowait actions
     */
	function stopAllActions(all=false) {
		//dm("All actions stop:" + all);
		var names = [];
		names.assign(allActions);
		(Dictionary.clear incontextof allActions)();
		var oldAction = false;
//		var newAction = false; // No-wait actions flag not needed as non-nowait always stop
		var update = false;
		for (var i=0;i<names.count;i+=2) {
			var name = names[i];
			var info = names[i+1];
			if (!info.nowait) {
				oldAction = true;
			}
			if (all || !info.nowait) {
				//dm("Target action for stop:" + name + ": " + info.nowait);
				internalActionComplete(info, true);
				invalidate info;
				delete names[name];
			} else {
				allActions[name] = info;
//				if (!info.nowait) {
//					newAction = true;
//				}
				update = true;
			}
		}
		// Update nowait portion (in case onFlipTimerInterval is not called during skip)
		if (!skipNoDisp && update) {
			updateAction(System.getTickCount());
		} else {
			if (oldAction/* && !newAction*/) {
				internalAllActionComplete();
			}
		}
		forEachEventHook('onStopAction',,all);
	}
    
    /**
     * Update action state
     * Called from entire system
	 * @param now current time
	 * @return true if running actions remain
     */
	function updateAction(now) {
		var names = [];
		names.assign(allActions);
		(Dictionary.clear incontextof allActions)();
		var oldAction = false;
		var newAction = false;
		var update = false;
		for (var i=0;i<names.count;i+=2) {
			var target = names[i];
			//dm("Action execution:" + target);
			var info   = names[i+1];
			if (!info.nowait) {
				oldAction = true;
			}
			if (info.doAction(now, kag.drawspeed == 0)) {
				//dm("Action ended:" + info.target);
				internalActionComplete(info, false);
				invalidate info;
            } else {
				// Re-register
				allActions[target] = info;
				if (!info.nowait) {
					newAction = true;
				}
				update = true;
			}
		}
		if (oldAction && !newAction) internalAllActionComplete();
		return update;
    }
    
    /**
     * Action completed (obsolete)
	 * Refer to internalActionComplete, internalAllActionComplete
     */
	function onActionCompleted(self) {}

	/**
	 * Wait for action
	 */
	function waitSingleAction(target, canskip=void, wait=0) {
		if (!isInAction(target)) return 0; // No action to wait for
		var name = 'action_' + (string)target;
		if((canskip === void || +canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip operation
                stopAction(target);
				return 0; // Stop auto-move and return immediately
			}
			conductor.wait(%[
				click : function (target)
				{
                    updateBeforeCh = 1;
                    stopAction(target); // Stop action
				} incontextof this,
				'click_arg' => target, // Argument to handler
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		else
		{
			conductor.wait(%[
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		return -2;
	}

	function waitAllAction(canskip, wait=0)	{
		// Wait for actions
		if (!isWorkingAction()) return 0; // No action to wait for
		if((canskip === void || +canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip operation
				stopAllActions(false);
				return 0; // Stop auto-move and return immediately
			}
			conductor.wait(%[
				click : function
				{
					updateBeforeCh = 1;
					stopAllActions(false); // Stop all actions
				} incontextof this,
				action : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				action_arg : wait
				]);
		}
		else
		{
			conductor.wait(%[
				action : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				action_arg : wait
				]);
		}
		return -2;
	}
	
	function waitAction(elm) {
		var target;
		if (elm.layer !== void) {
			target = getLayerFromElm(elm);
		} else if (typeof elm.target == "Object") {
			target = elm.target;
		} else if (typeof elm.target == "String") {
			target = Scripts.eval(elm.target);
		}
		if (target !== void) {
			if (isvalid target) {
				if (typeof target == "Object") {
					return waitSingleAction(target, elm.canskip, +elm.wait);
				} else {
					dm("Action wait must be specified on an object");
				}
			}
			return 0;
		} else {
			return waitAllAction(elm.canskip, +elm.wait);
		}
		return 0;
	}
	
	// Wait for action and transition simultaneously
	function waitSingleActionAndTransition(target, canskip, wait=0)	{
		if (!isInAction(target) && !target.inTransition) return 0; // Cannot wait
		var name = 'acttrans_' + (string)target;
		if((canskip === void || +canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip operation
				target.stopTransition(true);
				stopAction(target);
				return 0; // Stop auto-move and return immediately
			}
			conductor.wait(%[
				click : function(target)
				{
					updateBeforeCh = 1;
					if (isvalid target) {
						target.stopTransition(true);
						stopAction(target);
					}
				} incontextof this,
				'click_arg' => target, // Argument to handler
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		else
		{
			conductor.wait(%[
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		return -2;
	}
	
	// Wait for all actions and transitions to end
	function waitAllActionAndTransition(canskip, wait=0)	{
		if (!isWorkingAction() && transCount == 0) return 0;
		if((canskip === void || +canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip operation
				stopAllActions(false);
				stopAllTransitions(false);
				return 0; // Stop auto-move and return immediately
			}
			conductor.wait(%[
				click : function
				{
					updateBeforeCh = 1;
					stopAllActions(false);
					stopAllTransitions(false);
				} incontextof this,
				acttrans : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				acttrans_arg : wait,
				]);
		}
		else
		{
			conductor.wait(%[
				acttrans : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				acttrans_arg : wait,
				]);
		}
		return -2;
	}

	function waitActionAndTransition(elm) {
		var target;
		if (elm.layer !== void) {
			target = getLayerFromElm(elm);
		} else if (typeof elm.target == "Object") {
			target = elm.target;
		} else if (typeof elm.target == "String") {
			target = Scripts.eval(elm.target);
		}
		if (target !== void) {
			if (isvalid target) {
				if (typeof target == "Object") {
					return waitSingleActionAndTransition(target, elm.canskip, +elm.wait);
				} else {
					dm("Action wait must be specified on an object");
				}
			}
			return 0;
		} else {
			return waitAllActionAndTransition(elm.canskip, +elm.wait);
		}
	}
	
	//------------------------------------------------ Delay/Skip Related --

	function setDelay(elm)
	{
		// process delay tag
		var speed = elm.speed;
		if(speed == 'nowait')
		{
			chSpeed = 0;
			chUserMode = false;
		}
		else if(speed == 'user')
		{
			chUserMode = true;
			setUserSpeed();
		}
		else if(typeof speed == "String" && speed != "" && speed.charAt(0) == "x") {
			chSpeed = userChSpeed * +speed.substr(1);
			chUserMode = false;
		}
		else
		{
			chSpeed = +speed;
			chUserMode = false;
		}
		actualChSpeed = chSpeed;
	}

	function getCurrentRead()
	{
		// Plugin-side determination
		var ret;
		if ((ret = forEachFunctionHook("getCurrentRead")) !== void) {
			return ret;
		}

        // Always read during recollection
		if (isRecollection) {
			return true;
        }
		
        // Need to determine by line in auto-label mode
        if (autoLabelMode) {
			if (autoLabelCurrentRecordName != "") {
				//dm("Label:" + autoLabelCurrentRecordName);
				//dm("Flag:" + sflags[autoLabelCurrentRecordName]);
				//dm("Count:" + autoLabelCount);
				return (sflags[autoLabelCurrentRecordName] !== void &&
						sflags[autoLabelCurrentRecordName] > autoLabelCount);
            }
        }

        // Determine if current scenario part is already read
		return autoRecordPageShowing && currentRecordName != "" &&
				+sflags[currentRecordName] || !autoRecordPageShowing;
	}

	function setUserSpeed()
	{
		// Set user-selected character display speed
		// Assumes userChSpeed is already set to new value.
		// Or called to change speed based on read/unread status of label area.
		if(chUserMode)
		{
			if(getCurrentRead())
				chSpeed = userCh2ndSpeed==-1?userChSpeed:userCh2ndSpeed; // Already read
			else
				chSpeed = userChSpeed; // Unread
		}
		actualChSpeed = chSpeed;
	}

	function skipToClick()
	{
		// Skip to click waiting symbol
		skipMode = SKIP_CLICK;
	}

	function skipToPage()
	{
		// Skip to page break symbol
		skipMode = SKIP_PAGE;
	}

	function skipToStop(nodisp=false, tempallskip = void)
	{
		_tempAllskip = tempallskip;
		if (tempallskip !== void) callHook("onTempSkipToStop", tempallskip);

        // Only if all-skip or already read
        if (allskip || getCurrentRead()) {
            // Skip until next stop
            onPrimaryClick(true); // Emulate click
            skipMode = SKIP_STOP;
			callHook("onSkipToStop", allskip, nodisp);
			if (nodisp) {
				skipNoDisp = true;
			}
		}
	}

	function skipToStop2()
	{
		// Skip until next stop (fast-forward mode)
		showMessageLayerByUser() if(messageLayerHiding);
		onPrimaryClick(true);
		skipMode = SKIP_FAST;
		callHook("onSkipToStop2");
	}

	function skipToLabel(nodisp=false, stoplabel = "")
    {
        // For debug: Forced skip to next label
		onPrimaryClick(true);
		skipMode = SKIP_LABEL;
		skipToLabelStop = stoplabel;
		if (nodisp) {
			skipNoDisp = true;
			if (stoplabel != "" && skipNoDispWin !== void) {
				invalidate skipNoDispWin;
				skipNoDispWin = void;
			}
		}
    }
    
	function cancelSkip()
	{
		// Cancel skip operation
		if (skipMode == SKIP_FAST) skipKeyRepressed = false;
		skipMode = SKIP_NONE;
		_tempAllskip = void;
		callHook("onCancelSkip");
		setMenuAccessibleAll();
	}

	function enterNoWait()
	{
		// Process nowait tag
		beforeNoWaitActualChSpeed = actualChSpeed;
		beforeNoWaitChUserMode = chUserMode;
		actualChSpeed = 0;
	}

	function leaveNoWait()
	{
		// Process endnowait tag
		actualChSpeed = beforeNoWaitActualChSpeed;
		chUserMode = beforeNoWaitChUserMode;
	}

	function setAutoWait(elm)
	{
		// Set auto-wait
		autoWCEnabled = +elm.enabled if elm.enabled !== void;
		autoWCChars = elm.ch if elm.ch !== void;
		autoWCWaits = [].split(",", elm.time) if elm.time !== void;
	}

	function cancelAutoMode()
	{
        // Cancel auto-reading mode
		if (autoMode) {
			if (typeof this.autoModeMenuItem !== "undefined") {
                autoModeMenuItem.checked = false;
            }
			// Cancel auto-wait
			if (clickWaiting) {
				conductor.trigger("cancelauto");
			}
			autoMode = false;
			setMenuAccessibleAll();
		}
	}

	function enterAutoMode()
	{
        // Enter auto-reading mode
        if(typeof this.autoModeMenuItem !== "undefined")
            autoModeMenuItem.checked = true;
        // Behavior when waiting for click
		if (clickWaiting) {
			conductor.trigger('click');
			if (forEachFunctionHook("checkVoiceWait") !== void) {
				var t = conductor.lastTagName;
				if (t == 'p' || t == 'p2'){
					insertTag("p2");
				}
				else if(t == 'l'){
					insertTag("l");
				}
			}
		}
		autoMode = true;
    }
        
	//--------------------------------------------------------- Wait Related --

	function resetWait()
	{
		// Reset time origin
        timeOrigin = System.getTickCount();
	}

	function waitTime(waittime, canskip)
	{
		// Wait for waittime duration
		waittime *= effectspeed;
		if(waittime == 0) return 0;

		if(canskip)
		{
            conductor.waitWithTimeOut(%[
				click : function() {} incontextof this,
				timeout : function() {} incontextof this,
				], waittime);
		}
		else
		{
			// If not skippable
			conductor.waitWithTimeOut(%[
				timeout : function(arg)	{} incontextof this
				], waittime);
		}
		return -2; // break
		
	}

	function doWait(elm)
	{
		// Process wait tag
		var waittime;
		if(elm.mode == 'until')
		{
			// until mode
			waittime = timeOrigin + +elm.time - System.getTickCount();
			if(waittime < 0) { lastWaitTime = 0; return 0; } // Time already passed
			lastWaitTime = waittime;
			if(waittime < 6) return 0; // Duration too short to wait
		}
		else
		{
			waittime = +elm.time;
        }
		return waitTime(waittime, (elm.canskip === void || +elm.canskip) && clickSkipEnabled);
	}

	// Special wait
	// Invalidate timeOrigin if cancelled by click at least once
	function waitUntil(elm) {
		// until mode
		var waittime = timeOrigin + +elm.time - System.getTickCount();
		if(waittime < 0) { lastWaitTime = 0; return 0; } // Time already passed
		lastWaitTime = waittime;
		if(waittime < 6) return 0; // Duration too short to wait
		var canskip = (elm.canskip === void || +elm.canskip) && clickSkipEnabled;
		if (canskip) {
			// If skippable
			if(skipMode) {
				// During skip
				return 0; // Do nothing if skipping
			}
			conductor.waitWithTimeOut(%[
			click : function() {timeOrigin = 0;} incontextof this,
			timeout : function(){} incontextof this,
				], waittime);
		} else {
			// If not skippable
			conductor.waitWithTimeOut(%[
			timeout : function(){} incontextof this,
				], waittime);
		}
		return -2; // break
	}
	
	function doWaitCh(elm)
	{
		// Wait for character display count (+elm.time)
		var t = elm.time;
		return waitTime(actualChSpeed * (t === void ? 1 : +t),
			(elm.canskip === void || +elm.canskip) && clickSkipEnabled);
	}

	//--------------------------------------------------------- delay Related --

	var delayLabels  = %[]; // All delays
	var delayTimeList = []; // Time-based delay list (ascending order)

	// Update time-based delay info
	function updateDelay(tick) {
		while (delayTimeList.count > 0 && delayTimeList[0].time >= tick) {
			var info = delayTimeList.shift();
			extractDelay(info.name);
		}
		extractDelay(tick);
		return delayTimeList.count > 0 || conductor.hasDelay();
	}

	// Add time-based delay info
	function entryDelayTime(name, time) {
		var count = delayTimeList.count;
		var i=0;
		for (var i=0;i<count;i++) {
			if (delayTimeList[i].time > time) {
				delayTimeList.insert(i, %[name:name, time:time]);
				return;
			}
		}
		delayTimeList.push(%[name:name, time:time]);
	}

	// Register delay command
	function entryDelayCmd(elm) {
		var entry = false;
		var names = [];
		names.assign(elm);
		for (var i=0;i<names.count;i+=2) {
			var name = names[i];
			var time = names[i+1];
			if (name != "tagname" && name != "taglist") {
				entry = true;
				delayLabels[name] = true;
				entryDelayTime(name, System.getTickCount() + +time);
			}
		}
		if (entry) {
			flipStart();
		}
	}
	
	// Register wait label info
	function entryDelay(labels) {
		if (typeof labels == "Object") {
			if (labels instanceof "Dictionary") {
				var names = [];
				names.assign(labels);
				for (var i=0;i<names.count; i+=2) {
					delayLabels[names[i]] = true;
				}
			} else if (labels instanceof "Array") {
				for (var i=0;i<labels.count; i++) {
					delayLabels[labels[i]] = true;
				}
			}
		} else if (typeof labels == "String") {
			delayLabels[labels] = true;
		}
	}

	var keywaitLabelCount = 0;
	
	function clearDelay() {
		(Dictionary.clear incontextof delayLabels)();
		keywaitLabelCount = 0;
	}

	// Discard wait labels
	function cancelDelay() {
		conductor.cancelDelay();
		clearDelay();
	}

	function doneDelay(flag) {
		forEachEventHook('onDoneDelay');
		delayQueue.clear();
		extractTrigger.cancel();
		trigger("delay_*");
		clearDelay();
		conductor.extractDelay(void, flag);
	}
	
	var delayQueue = [];

	var extractTrigger;
	
	// Release wait label
	function extractDelay(name) {
		if (!isvalid this || !isvalid extractTrigger) return; //[XXX] Callback might occur from sound stopping system during shutdown
		delayQueue.push(name);
		extractTrigger.trigger();
	}

	function doExtractDelay() {
		var name;
		while ((name = delayQueue.shift()) !== void) {
			if (name === void || name === "*") {
				trigger("delay_*");
				clearDelay();
			} else if (typeof name == "String") {
				if (delayLabels[name] !== void) {
					delete delayLabels[name];
				}
				trigger("delay_" + name);
			}
			conductor.extractDelay(name);
		}
	}

	function waitDelay(name, canskip=true)
	{
		//dm("Waiting for delay:" + name + ":" +delayLabels[name]);
		if (name === void || delayLabels[name] === void) return 0;
		if(canskip !== void && +canskip && clickSkipEnabled)
		{
			// If skippable
			if(skipMode)
			{
				// During skip
				return 0; // Return without doing anything if skipping
			}

			conductor.wait(%[
				click : function() { clearDelay(); } incontextof this,
				"delay_" + name => function(){} incontextof this,
				"delay_*" => function(){} incontextof this,
				]);
		}
		else
		{
			// If not skippable
            conductor.wait(%[
				"delay_" + name => function(){} incontextof this,
				"delay_*" => function(){} incontextof this,
				]);
		}
		return -2; // break
	}
	
	//------------------------------------------------------------ quake Related --

	function doQuake(elm)
	{
		// Start quake according to elm
		if(elm.time !== void)
		{
			if(defaultQuakeTimeInChUnit)
			{
				if(elm.timemode == 'ms')
					quakeEndTick = System.getTickCount() + +elm.time;
				else
					quakeEndTick = System.getTickCount() + +elm.time * chSpeed;
			}
			else
			{
				if(elm.timemode == 'delay')
					quakeEndTick = System.getTickCount() + +elm.time * chSpeed;
				else
					quakeEndTick = System.getTickCount() + +elm.time;
			}
		}
		else
		{
			quakeEndTick = -1;
		}

		if(elm.hmax !== void) quakeHorzMax = +elm.hmax; else quakeHorzMax = 10;
		if(elm.vmax !== void) quakeVertMax = +elm.vmax; else quakeVertMax = 10;

		quakeTimer.enabled = true;
		quaking = true;
	}

	function restoreQuake()
	{
		// Called from restore; resume shaking if it was active when bookmark was saved
		if(quaking && quakeEndTick == -1)
			quakeTimer.enabled =true;
	}

    /**
     * Layer position adjustment
     * Automatically offsets message layer positions
     */
	function setBaseLayerPos(x, y) {
		(global.Layer.setPos incontextof fore.base)(x,y);
		(global.Layer.setPos incontextof back.base)(x,y);
		if (!quakeMessageLayer) {
			for(var i = 0; i< fore.messages.count; i++) fore.messages[i].setDiff(-x, -y);
			for(var i = 0; i< back.messages.count; i++) back.messages[i].setDiff(-x, -y);
        }
		forEachEventHook('setBaseLayerPos',
						 function(handler, info) { handler(info.x, info.y); } incontextof this, %[x:x, y:y]);
	}

    
	function stopQuake()
	{
		// Stop shaking
		setBaseLayerPos(0, 0);
		quakeTimer.enabled = false;
		quaking = false;
		conductor.trigger('quake');
	}

	function getForceDisableQuakeState()
	{
		// Check if shaking is disabled
		return historyShowing || selectShowing || mapSelectShowing || panelShowing || currentDialog !== void ||
			(forceDisableQuakeOnExtraConductor && usingExtraConductor);
	}

	function onQuakeTimerInterval()
	{
		// Called by quakeTimer
		if(quakeEndTick != -1 && System.getTickCount() > quakeEndTick) { stopQuake(); return; }
		if(getForceDisableQuakeState())
		{
			// Shaking cannot occur while message history is displayed
			setBaseLayerPos(0, 0);
			return;
		}
		var x, y;
		if(quakeHorzMax == quakeVertMax)
		{
			// Roughly same
			x = int(Math.random() * quakeHorzMax *2 - quakeHorzMax);
			y = int(Math.random() * quakeVertMax *2 - quakeVertMax);
		}
		else if(quakeHorzMax < quakeVertMax)
		{
			// Vertical shake
			x = int(Math.random() * quakeHorzMax *2 - quakeHorzMax);
			y = int((quakePhase ? Math.random() : -Math.random()) * quakeVertMax);
		}
		else
		{
			// Horizontal shake
			x = int((quakePhase ? Math.random() : -Math.random()) * quakeHorzMax);
			y = int(Math.random() * quakeVertMax*2 - quakeVertMax);
		}
		quakePhase = !quakePhase;
		setBaseLayerPos(x, y);
	}

	function waitQuake(elm)
	{
		// Wait until shaking ends
		if(!quaking || quakeEndTick == -1) return 0; // Don't wait if not shaking
		if(elm.canskip !== void && +elm.canskip && clickSkipEnabled)
		{
			// If skippable
			if(skipMode && effectspeed==0)
			{
				// During skip
				stopQuake();
				return 0; // Stop shake and return if skipping
			}
			conductor.wait(%[
				click : function
				{
					stopQuake(); // Shaking stops
				} incontextof this,
				quake : function(arg)
				{
					// No action
					return arg;
				} incontextof this,
				quake_arg : +elm.wait
				]);
		}
		else
		{
			// If not skippable
			conductor.wait(%[
				quake : function(arg)
				{
					// No action
					return arg;
				} incontextof this,
				quake_arg : +elm.wait
				]);
		}
		return -2;
	}

	//------------------------------------------------------------- Click --

	function onPrimaryClick(force = false)
	{
        // Called from primary layer when "Click Action" is not filtered
		clickCount++ if (!force);
		if(force || !callHook(leftClickHook))
		{
			if(messageLayerHiding)
			{
				showMessageLayerByUser(); // Show message layer
				if (!force) return;
			}
//          else
            {
				var st = conductor.status;
				var runst = conductor.mRun;
				var stopst = conductor.mStop;

                if(st != stopst && canCancelSkipByClick && skipMode && skipMode < SKIP_FAST && cancelSkipWhenClick)
				{
					// Cancel skip by click possible
					cancelSkip();
					return;
				}

				// Processing for beginskip
				// Normally skips, but if enableLeftBeginSkip is disabled, ignore skip
				if (prevSkipMode !== void) {
					if (enableLeftBeginSkip) {
						skipMode = SKIP_CANCEL;
						conductor.trigger('click');
					}
					return;
				}

                {
					// Messages not filtered at this point clear wait state
					// Notify conductor by sending 'click' trigger
					if(!conductor.trigger('click')) // Ignored if not in wait state
					{
						// If not processed (e.g. handler not found)
						if(st == runst && clickSkipEnabled && skipMode == SKIP_NONE)
						{
							// Click-to-skip possible
							skipToClick();
						}
                    }
				}

				// Reordered. Cancel auto-mode after click cancellation processing
				if (st != stopst && autoMode && cancelAutoWhenClick) {
					cancelAutoMode();
                }
                
            }
		}
	}

	function onPrimaryClickByKey()
	{
		// Same behavior as primary layer click when key pressed, but temporarily hides cursor
		onPrimaryClick();
		hideMouseCursor();
	}

	function waitClick(elm)
	{
		// Forced skip during beginskip/endskip
		if (skipMode >= SKIP_CANCEL) return  0;

		// Wait for click
		conductor.wait(%[
			click : function
			{
				inSleep = false;
				notifyRun();
			} incontextof this]);
		inSleep = true;
		notifyStable();
		return -2;
	}

	function onMouseDown(x, y)
	{
		lastMouseDownX = x;
		lastMouseDownY = y;
		super.onMouseDown(...);
	}

	function onMouseUp(x, y, btn)
	{
		conductor.trigger("mouseup" + btn);
		super.onMouseUp(...);
		// [XXX] When dialog is shown in modal state, clicks outside layer bounds might not be detected
		if (currentDialog !== void && btn == mbRight) with (sysbase) {
			var x = .cursorX, y = .cursorY, left = .left, top = .top;
			if (x < left || y < top || x >= left+.width || y >= top+.height) {
				onPrimaryRightClick(); // Hook in DialogLayer gets Right Click action
			}
		}
	}

	// Processing for clicks outside primary layer in native fullscreen (requires WindowEX)
	var _windowsClickEventMessageMap = %[];
	function setWindowsClickEventHook() {
		if (typeof this.setMessageHook != "Object" ||
			typeof global.Window.getNotificationNum != "Object") return;
		var setMH = setMessageHook;
		var getMN = global.Window.getNotificationNum;
		var map   = _windowsClickEventMessageMap;
		var ev    = [ "LBUTTONDOWN", "RBUTTONDOWN", "LBUTTONDBLCLK", "RBUTTONDBLCLK" ];
		for (var i = 0; i < ev.count; i++) {
			var name = ev[i];
			setMH(true, name);
			map[name] = getMN(name);
		}
	}
	function onWindowsMessageHook(msg, wp, lp) {
		with (_windowsClickEventMessageMap) switch (msg) {
		case .LBUTTONDOWN: case .LBUTTONDBLCLK:
			//dm("outer click");
			onPrimaryClick();
			break;
		case .RBUTTONDOWN: case .RBUTTONDBLCLK:
			//dm("outer Rclick");
			onPrimaryRightClick();
			break;
		}
		return callHook("onWindowsMessageHook", msg, wp, lp);
	}

	//------------------------------------------------------- Keyboard Operations --

	function processKeys(key, shift)
	{
		if (key == VK_BACK && (shift == ssShift) && autoLabelStore !== void
			&& typeof this.backToAutoLabelStoreMenuItem == "Object")
		{
			backToAutoLabelStoreMenuItem.click();
		}

        // Skip processing via CONTROL
        if(key == VK_CONTROL) {
			var sg = getKeyState;
			if(sg(VK_CONTROL)){
				if (conductor.status != conductor.mStop && !conductor.interrupted &&
					clickSkipEnabled && skipMode < SKIP_FAST &&
					(prevSkipMode === void || enableLeftBeginSkip) // If left click disabled for beginskip, suppress CTRL skip too
					) {
					skipToStop2(); // Fast-forward mode if not in skipMode 4
				}
			}
        }

        if(checkProceedingKey(key, shift)) return;

		if(key == #'F')
		{
			// Proceed to next choice/unread
			skipToNextStopByKey();
			return;
		}

		if(key == #'B')
		{
			// Back to previous
			goBackByKey();
			return;
		}

		if(key == #'A')
		{
			// Auto-read
			switchAutoModeByKey();
			return;
		}
 
		if(freeSaveDataMode)
		{
			if(key == #'S')
			{
				// Save bookmark
				return menuItemClickByKey("storeMenu");
			}

			if(key == #'L')
			{
				// Load bookmark
				return menuItemClickByKey("restoreMenu");
			}
		}

		if(key == #'R' || (shift == ssShift && key == VK_UP))
		{
			// Show message history
			showHistoryByKey();
			return;
		}

		if(key == VK_ESCAPE)
		{
			// Hide message
			return menuItemClickByKey("rightClickMenuItem");
		}
	}

	function preProcessKeys(key, shift)
	{
		return callHook(keyDownHook, key, shift);
	}

	function internalOnKeyDown(key, shift)
	{
		if(!preProcessKeys(key, shift)) processKeys(key, shift);
	}

	function checkProceedingKey(key, shift)
	{
        // If key is progression key (Space or Return), process and return true. Otherwise false.
		if(key == VK_RETURN || key == VK_SPACE)
		{
			// Check if key is actually pressed via getKeyState as it might be queued
			var sg = getKeyState;
			if(sg(VK_RETURN) || sg(VK_SPACE))
			{
				// Key pressed
				if((shift & ssRepeat) && clickSkipEnabled)
				{
					// Key repeat
					if(skipMode < SKIP_FAST && skipKeyRepressed && skipKeyRepeatEnabled)
						skipToStop2(); // Enter fast-forward if not already in skipMode 4
					// skipKeyRepressed checks prevent entering skip after cancelSkip during repeated events
				}
				else
				{
					skipKeyRepressed = true;
					onPrimaryClickByKey();
				}
				return true;
			}
		}

		return false;
	}

	function skipCancelKeyPressing()
	{
		// Check if keys/buttons that trigger skip cancellation are pressed
		var sg = getKeyState;
		return sg(VK_RETURN) || sg(VK_SPACE) || sg(VK_LBUTTON);
	}

	function skipKeyPressing()
	{
		// Check if VK_RETURN, VK_SPACE or VK_CONTROL are pressed
		var sg = getKeyState;
		return (skipKeyRepeatEnabled && (sg(VK_RETURN) || sg(VK_SPACE))) || sg(VK_CONTROL);
	}

	function releaseCapture() {
		// Layer for releaseCapture doesn't matter
		primaryLayer.releaseCapture();
	}

	// Function to click menu items
	function menuItemClickByKey(menuItem) {
		releaseCapture(); // Release mouse capture
		// If string passed, refer to own variable as menu item
		if (typeof  menuItem == "String" && typeof this[menuItem] != "undefined") menuItem = this[menuItem];
		// Emulate click if object is valid menu item and enabled
		if (typeof  menuItem == "Object" && menuItem instanceof "MenuItem" &&
			isvalid menuItem && menuItem.enabled) menuItem.click();
	}

	function goBackByKey()
	{
		menuItemClickByKey("goBackMenuItem");
	}

	function skipToNextStopByKey()
	{
		menuItemClickByKey("skipToNextStopMenuItem");
	}

	function showHistoryByKey()
	{
		menuItemClickByKey("showHistoryMenuItem");
	}

	function switchAutoModeByKey()
	{
		menuItemClickByKey("autoModeMenuItem");
	}

	function onKeyDown(key, shift)
	{
		if(pseudoMenuShortcut(key, shift)) return;
		if(focusedLayer === null)
			internalOnKeyDown(key, shift);
		super.onKeyDown(...);
	}
	function onKeyUp(key, shift)
	{
		callHook("keyUp", key, shift);
		super.onKeyUp(...);
	}

	function onMouseWheel(shift, delta, x, y)
	{
		// Wheel rotated
		super.onMouseWheel(...);

		// Hook processing
		if (callHook("onMouseWheelHook", shift, delta, x, y)) return;

		// Always pass to dialog if displayed
		if (currentDialog !== void) {
			// Execute if wheel processing exists
			currentDialog.processWheel(...) if (currentDialog.hasWheel());
			return;
		}
		// Pass to panel if it can accept
		if (panelShowing && panelLayer.hasWheel()) {
			panelLayer.processWheel(...);
			return;
		}
		// Message window wheel processing
		if (inSleep && current.hasWheel()) {
			current.processWheel(...);
			return;
		}
		// Stream events to message history if displayed
		if (historyShowing) {
			historyLayer.windowMouseWheel(...);
			return;
		}
		return internalOnMouseWheel(...);
	}

	function internalOnMouseWheel(shift, delta, x, y)
	{
		if (delta > 0) {
			// Wheel up
			showHistoryByKey(); // Show history
		} else if (delta < 0) {
			// Wheel down
			if (System.getTickCount() - lastHistoryHiddenTick > 150) onPrimaryClick(); // Emulate click
			// ↑ Tick comparison prevents unintentional progression when hiding history and scrolling down sequentially
		}
	}

	//------------------------------------------------- Click Waiting Glyph Processing --

	function hideClickGlyphs()
	{
		// Hide click wait symbols
		lineBreak.visible = false;
		pageBreak.visible = false;
		if(conductor == mainConductor)
		{
			// Record click wait glyph state
			lastClickGlyphVisible = false;
		}
	}

	function storeClickGlyphState(which)
	{
		// Temporarily store click wait glyph info
		// Refers to this when returning from right-click or extraConductor subroutines
		if(conductor == mainConductor)
