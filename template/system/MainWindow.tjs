	//-------------------------------------------------- onCloseQuery/close --



    function onCloseYes() {

        shutdown();

    }



	function onCloseQuery()

	{

		saveSystemVariables();

        if(!askOnClose) {

			// Avoid closing console while maximized

			return super.onCloseQuery(true);

		}

		if (!callHook("onCloseQuery") && currentDialog === void) {

            askYesNo("Do you want to exit?", "Confirm", onCloseYes);

        }

        super.onCloseQuery(false);

    }



	function close()

	{

		callHook("onCloseHook") if(!askOnClose);

		// Close window

		saveSystemVariables();

		super.close(...);

	}



	function shutdown()

	{

		// Close window without confirmation

		// Performing close within this method invalidates various objects, 

		// which may cause errors upon returning.

		// Therefore, perform shutdown via AsyncTrigger after returning from all methods.

		global.shutdownTrigger =

			new AsyncTrigger(handleShutdown, '');

		global.shutdownTrigger.cached = true;

		global.shutdownTrigger.trigger();

		if(conductor.status == conductor.mRun)

			conductor.interrupt();

			// Tell conductor to interrupt if it's running

	}



	function handleShutdown()

	{

		// Method to actually process shutdown request from shutdown()

		var askOnClose_save = askOnClose;

		askOnClose = false;

		close();

		if(this isvalid) askOnClose = askOnClose_save;

	}



	function closeByScript(elm)

	{

		// Close window

		// Slightly complex logic for the same reason as shutdown.

		// If "No" is selected and window doesn't close, 

		// 'not_closed' trigger is issued and execution resumes.

		var askOnClose_save = askOnClose;

		if(elm.ask !== void && !(+elm.ask)) askOnClose = false;

		global.shutdownTrigger =

			new AsyncTrigger(handleCloseByScript, '');

		global.shutdownTrigger.cached = true;

		global.shutdownTrigger.trigger();



		// closeByScript shows "Exit?" dialog immediately after this handler ends.

		// If exiting, exit as-is.

		// If not exiting, 'not_closed' trigger is issued and execution continues.

		conductor.wait(%[

			not_closed : askOnClose_save

			? (function

			{

				// This won't actually be called, but just in case

				askOnClose = true;

			} incontextof this)

			: (function

			{

			} incontextof this)

			]);

	}



	function handleCloseByScript()

	{

		// Method to actually process shutdown request from shutdown()

		close();

		if(this isvalid) // If "No" was selected

			conductor.trigger('not_closed');

	}



	//------------------------------------------------------ Plugin Processing --



	function forEachEventHook(method, func, arg)

	{

		// Execute func for each plugin object's method

		// Arguments of func are each element and arg

		if(kagPlugins.count)

		{

			var array = [];

			array.assign(kagPlugins); // Copy first and execute on the copy

			var arraycount = array.count;

			if (func !== void) {

				for(var i =0; i<arraycount; i++)

				{

					var obj = array[i];

					if(typeof obj[method] != "undefined")

						func(obj[method], arg);

				}

			} else {

				for(var i =0; i<arraycount; i++)

				{

					var obj = array[i];

					if(typeof obj[method] != "undefined")

						obj[method](arg);

				}

			}

		}

	}



	function addPlugin(plugin)

	{

		// Add plugin object

		kagPlugins.add(plugin);

	}



	function removePlugin(plugin)

	{

		// Remove plugin object

		kagPlugins.remove(plugin);

	}



	//---------------------------------------------------------- Layer Function Calls --



	/**

	 * Method calls for all layers

	 * param.command: Method name

	 * param.args: Arguments

	 */

	function onLayerCommand(param) {

		var layers, messages;

		fore.base[param.command](param.args*);

		layers = fore.layers, messages = fore.messages;

		for(var i = layers.count-1; i >= 0; i--) layers[i][param.command](param.args*);

		for(var i = messages.count-1; i >= 0; i--) messages[i][param.command](param.args*);

		back.base[param.command](param.args*);

		layers = back.layers, messages = back.messages;

		for(var i = layers.count-1; i >= 0; i--) layers[i][param.command](param.args*);

		for(var i = messages.count-1; i >= 0; i--) messages[i][param.command](param.args*);

		forEachEventHook('onLayerCommand',,param);

	}

	

	//---------------------------------------------------------- Hook Processing --



	var hookMap = %[ keyDown:this.keyDownHook, leftClick:this.leftClickHook, rightClick:this.rightClickHook, mouseMove:this.mouseMoveHook ];

