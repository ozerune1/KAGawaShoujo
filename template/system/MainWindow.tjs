	/**

	 * Safe evalStorage (prevents hacks by eval from outside)

	 */

	var disableSafeEvalStorage = false; // Allow suppression in Config.tjs

	function safeEvalStorage(fn, *) {

		if (!disableSafeEvalStorage) {

			var tmp = [].load(fn, *);

			// Judge based on whether (const) is at the beginning

			if (tmp[0] == "" || tmp[0].indexOf("(const)") != 0)

