	//------------------------------------------------------ Special Variable Processing --
    // Add simple reference methods/properties for system screens

	/**
	 * Set global WaveSound volume
	 * 100 level setting
	 */
	property wavevolume {
		getter()  {
			return scflags.waveVolume !== void ? +scflags.waveVolume : global.WaveSoundBuffer.globalVolume / 1000;
		}
		setter(v) {
			v = +v;
			if      (v < 0)   v = 0;
			else if (v > 100) v = 100;
			scflags.waveVolume = v;
			global.WaveSoundBuffer.globalVolume = scflags.waveEnable ? v * 1000 : 0;
		}
	}

	/**
	 * Set global WaveSound enable value
	 * true / false
	 */
	property waveenable {
		getter() {
			return scflags.waveEnable !== void ? +scflags.waveEnable : true;
		}
		setter(v) {
			scflags.waveEnable = +v;
			wavevolume = scflags.waveVolume;
		}
	}

	/**
	 * Set BGM enable value
	 * true / false
	 */
	property bgmenable {
		getter()  { return getSoundProperty("bgm", "enable", true); }
		setter(v) {        setSoundProperty("bgm", "enable", !!v);
			/**/           bgm.restoreSystemState(scflags); }
	}

	/**
	 * Set BGM volume
	 * 100 level setting
	 */
	property bgmvolume {
		getter()  { return getSoundProperty("bgm", "globalVolume", 100000) / 1000; }
		setter(v) {        setSoundProperty("bgm", "globalVolume",      v  * 1000);
			/**/           bgm.restoreSystemState(scflags); }
	}

	/**
	 * Set SE enable value
	 * true / false
	 */
	property seenable {
		getter()  { return getSEGroupProperty("enable", true); }
		setter(v) {        setSEGroupProperty("enable", !!v);  }
	}

	/**
	 * Set SE volume
	 * 100 level setting
	 */
	property sevolume {
		getter()  { return getSEGroupProperty("globalVolume", 100000) / 1000;  }
		setter(v) {        setSEGroupProperty("globalVolume",       v * 1000); }
	}


	// System SE enable/volume
	property _sysse_group { getter { return sameSysSEVolume ? void : "sysse"; } }
	property sysseenable {
		getter()  { return getSEGroupProperty("enable", true, _sysse_group); }
		setter(v) {        setSEGroupProperty("enable", !!v,  _sysse_group); }
	}
	property syssevolume {
		getter()  { return getSEGroupProperty("globalVolume", 100000,   _sysse_group) / 1000; }
		setter(v) {        setSEGroupProperty("globalVolume", v * 1000, _sysse_group);        }
	}

	function doSEGroup(grp, callback, *) {
		var flags = scflags.se;
		if (flags === void) scflags.se = flags = [];
		var from = 0, to = -1; // to : end+1
		switch (grp) {
		case void: case "":
			from = 0;
			to   = numSEBuffers;
			to  += numSysSEBuffers if (sameSysSEVolume);
			break;
		case "sysse":
			from = numSEBuffers;
			to   = numSEBuffers + numSysSEBuffers;
			break;
		default:
			// Allow expansion?
		}
		if (from >= to) return void;
		//dm("doSEGroup", grp, from, to);
		for (var i = from; i < to; i++) {
			if (se[i] === void) continue;
			var dic = flags[i];
			if (dic === void) flags[i] = dic = %[];
			if (callback(se[i], dic, *)) break;
		}
	}

	function setSEGroupProperty(prop, value, grp) {
		doSEGroup(grp, function (se, flag, prop, value) {
			flag[prop] = value;
			se.restoreSystemState(scflags);
		} incontextof this, prop, value);
		callHook("onSoundPropertyChanged", (grp == "" ? "se" : grp), prop, value);
	}

	function getSEGroupProperty(prop, defval, grp) {
		var dic = %[];
		doSEGroup(grp, function (se, flag, prop, dic) {
			if (flag[prop] !== void) dic.result = flag[prop];
			return true;
		} incontextof this, prop, dic);
		return (typeof dic.result !== "undefined") ? dic.result : defval;
	}

	// Read/Change sound-related settings
	function getSoundProperty(tag, prop, defval) {
		var table = scflags[tag];
		return (table !== void && table[prop] !== void) ? table[prop] : defval;
	}
	function setSoundProperty(tag, prop, value) {
		var table = scflags[tag];
		if (table === void) table = scflags[tag] = %[];
		table[prop] = value;
		callHook("onSoundPropertyChanged", tag, prop, value);
	}


	/**
	 * Set voice enable value
	 * true / false
	 */
	property voiceenable {
		getter()  { return getSoundProperty("voice", "enable", true); }
		setter(v) {        setSoundProperty("voice", "enable", !!v);  }
	}

	/**
	 * Representative volume of voice
	 * 100 level setting
	 */
	property voicevolume {
		getter()  { return getSoundProperty("voice", "globalVolume", 100000) / 1000; }
		setter(v) {        setSoundProperty("voice", "globalVolume",      v  * 1000);
			/**/           forEachEventHook('onVoiceVolumeUpdate'); }
	}

	// Normalize name passed in {get/set}Voice{On/Volume}
	function _voiceNameFilter(name) {
		@if (DEBUG)
			// Reusing scflags.voice, so the following names collide (though unlikely to be used)
			if (name == "enable" || name == "globalVolume")
				errorCmd("{get/set}Voice{On/Volume}: Reserved word specified as voice name");
		@endif
		return (name != "") ? name : "etc";
	}

	/**
	 * Whether voice of the character with specified name is enabled
	 */
	function getVoiceOn(name) {
		return getSoundProperty("voiceon", _voiceNameFilter(name), true);
	}

	/**
	 * Enable voice of character with specified name
	 */
	function setVoiceOn(name, on=true) {
		setSoundProperty("voiceon", _voiceNameFilter(name), !!on);
	}

	/**
	 * Get voice volume of character with specified name
	 * @param name Character name
	 * @param rawvalue If true, does not correct for voicevolume
	 */
	function getVoiceVolume(name, rawvalue = false) {
		var vol = getSoundProperty("voice", _voiceNameFilter(name), 100000) / 1000;
		return rawvalue ? vol : (vol * voicevolume / 100);
	}

	/**
	 * Change voice volume of character with specified name
	 */
	function setVoiceVolume(name, vol) {
		setSoundProperty("voice", _voiceNameFilter(name), vol * 1000);
		forEachEventHook('onVoiceVolumeUpdate');
	}

	/**
	 * Set BGV enable value
	 * true / false
	 */
	property bgvenable {
		getter()  { return getSoundProperty("bgv", "enable", true); }
		setter(v) {        setSoundProperty("bgv", "enable", !!v);  }
	}
	property bgv2enable {
		getter()  { return getSoundProperty("bgv2", "enable", true); }
		setter(v) {        setSoundProperty("bgv2", "enable", !!v);  }
	}

	/**
	 * Representative volume of BGV
	 * 100 level setting
	 */
	property bgvvolume {
		getter()  { return getSoundProperty("bgv", "globalVolume", 100000) / 1000;  }
		setter(v) {        setSoundProperty("bgv", "globalVolume",      v  * 1000);
			/**/           forEachEventHook('onVoiceVolumeUpdate');
		}
	}
	property bgv2volume {
		getter()  { return getSoundProperty("bgv2", "globalVolume", 100000) / 1000;  }
		setter(v) {        setSoundProperty("bgv2", "globalVolume",      v  * 1000);
			/**/           forEachEventHook('onVoiceVolumeUpdate');
		}
	}

	/**
	 * Get loop voice volume for specified character name
	 */
	function getBGVVolume (name) { return bgvvolume  * getVoiceVolume(name, true) / 100; }
	function getBGV2Volume(name) { return bgv2volume * getVoiceVolume(name, true) / 100; }

	/**
	 * Set Movie audio enable value
	 * true / false
	 */
	property movieAudioEnable {
		getter()  { return !independentMovieAudioProperty ? bgmenable :
			/**/    getSoundProperty("movie", "enable", true); }
		setter(v) { setSoundProperty("movie", "enable", !!v);  }
	}

	/**
	 * Movie audio volume
	 * 100 level setting
	 */
	property movieAudioVolume {
		getter()  { return !independentMovieAudioProperty ? bgmvolume :
			/**/    getSoundProperty("movie", "globalVolume", 100000) / 1000; }
		setter(v) { setSoundProperty("movie", "globalVolume",      v  * 1000); }
	}


    /**
     * Text speed control
     * Specify 0 to _textSpeedMax (_textSpeedMax is fastest)
     */
	var _textSpeedMax = 10;
    property textspeed {
        getter() {
			var max = _textSpeedMax;
            return max - (userChSpeed / (chSpeeds.slow / max));
        }
        setter(v) {
			var max = _textSpeedMax;
            userChSpeed = (max - v) * (chSpeeds.slow / max);
			callHook("onTextSpeedChanged", textspeed);
            if (userChSpeed <= chSpeeds.fast) {
                if (typeof this.chFastMenuItem != "undefined") {
                    this.chFastMenuItem.checked = true;
                }
            } else if (userChSpeed <= chSpeeds.normal) {
                if (typeof this.chNormalMenuItem != "undefined") {
                    this.chNormalMenuItem.checked = true;
                }
            } else {
				if (typeof this.chSlowMenuItem != "undefined") {
                    this.chSlowMenuItem.checked = true;
                }
            }
        }
    }

    /**
     * Wait time control during auto-play
     * Specify 0 to _autoSpeedMax (_autoSpeedMax is fastest)
     */
	var _autoSpeedMax = 10;
    property autospeed {
        getter() {
			var max = _autoSpeedMax;
            return max - (autoModePageWait / (autoModePageWaits.slow / max));
        }
        setter(v) {
			var max = _autoSpeedMax;
            autoModePageWait = (int)((max - v) * (autoModePageWaits.slow / max));
            autoModeLineWait = (int)((max - v) * (autoModeLineWaits.slow / max));
			callHook("onAutoSpeedChanged", autospeed);
            if (autoModePageWait <= autoModePageWaits.fast) {
                if (typeof this.autoModeFastMenuItem != "undefined") {
                    this.autoModeFastMenuItem.checked = true;
                }
            } else if (autoModePageWait <= autoModePageWaits.faster) {
                if (typeof this.autoModeFasterMenuItem != "undefined") {
                    this.autoModeFasterMenuItem.checked = true;
                }
            } else if (autoModePageWait <= autoModePageWaits.medium) {
                if (typeof this.autoModeMediumMenuItem != "undefined") {
                    this.autoModeMediumMenuItem.checked = true;
                }
            } else if (autoModePageWait <= autoModePageWaits.slower) {
                if (typeof this.autoModeSlowerMenuItem != "undefined") {
                    this.autoModeSlowerMenuItem.checked = true;
                }
            } else {
                if (typeof this.autoModeSlowMenuItem != "undefined") {
                    this.autoModeSlowMenuItem.checked = true;
                }
            } 
        }
    }

	function updateEffectButton() {
		forEachEventHook('onUpdateEffect');
		if (noeffect) {
			if (typeof this.noeffectMenuItem != "undefined") {
				this.noeffectMenuItem.checked = true;
			}
		} else {
			if (typeof this.effectMenuItem != "undefined") {
				this.effectMenuItem.checked = true;
			}
		}
		if (typeof this.effectCheckMenuItem != "undefined") {
			this.effectCheckMenuItem.checked = !noeffect;
		}
	}
	
    /**
     * Draw speed (Specify playback ratio for transitions)
     */
    property drawspeed {
        getter() {
			if (!noeffectEnabled || scflags.drawspeed === void) {
				return 1.0;
			}
			return scflags.drawspeed;
        }
        setter(v) {
			scflags.drawspeed = v;
			updateEffectButton();
        }
    }

    /**
	 * Draw speed correction during skip
	 */
	property skipspeed {
		getter() {
			if (scflags.skipspeed === void) {
				return 0;
			}
			return scflags.skipspeed;
		}
		setter(v) {
			scflags.skipspeed = v;
			updateEffectButton();
        }
    }

	property actskipspeed {
		getter() {
			return skipMode > SKIP_STOP ? 0 : skipMode ? skipspeed : 1.0;
		}
	}

	property effectspeed {
		getter() {
			if (skipNoDisp) {
				return 0;
			} 
			var draw = noeffectEnabled ? drawspeed : 1.0;
			return draw * actskipspeed;
		}
	}
	
    /**
     * Effect Enable/Disable (Linked with transition correction)
     */
    property noeffect {
        getter() {
            if (scflags.drawspeed === void) {
                return false;
            }
            return scflags.drawspeed == 0;
        }
        setter(v) {
            if (v) {
                scflags.drawspeed = 0;
			} else {
				delete scflags.drawspeed;
			}
			updateEffectButton();
        }
    }

    /**
     * Voice playback speed multiplier
     */
    property voicespeed {
		getter() {
			if (scflags.voicespeed === void) {
                return 1.0;
            }
            return scflags.voicespeed;
        }
        setter(v) {
			if (scflags.voicespeed != v) {
				scflags.voicespeed = v;
				forEachEventHook('onVoiceSpeedUpdate');
				updateVoiceSpeedMenu(v);
			}
        }
    }

	function updateVoiceSpeedMenu(value = this.voicespeed)
	{
		// Update checkmarks for voice speed control menu
		if(typeof this.voiceSpeedMenu !== "undefined") {
			var children = voiceSpeedMenu.children;
			for (var i = children.count-1; i >= 0; i--) {
				var item = children[i];
				if (typeof item.speed !== "undefined" && item.speed == value) {
					item.checked = true;
					break;
				}
			}
		}
	}
	function onVoiceSpeedMenuItemClick(sender)
	{
		//sender.checked = true; //*Set in updateVoiceSpeedMenu
		voicespeed = sender.speed;
	}

    // ----------------------------------------------------------
    // Error Log Processing
    // ----------------------------------------------------------

    // Default debug level
    var _debugLevel = tkdlNone;
    
    /**
     * Debug Level
     */
    property debugLevel {
        setter(v) {
            _debugLevel = v;
            if (mainConductor !== void) {
                mainConductor.debugLevel = v;
                extraConductor.debugLevel = v;
            }
        }
        getter() {
            return _debugLevel;
        }
    }

	function onDebugLevelNoneMenuItemClick(sender)
	{
        debugLevel = tkdlNone;
        if(typeof this.debugLevelNoneMenuItem != "undefined")
            debugLevelNoneMenuItem.checked = true;
        saveSystemVariables();
	}

	function onDebugLevelSimpleMenuItemClick(sender)
	{
        debugLevel = tkdlSimple;
        if(typeof this.debugLevelSimpleMenuItem != "undefined")
            debugLevelSimpleMenuItem.checked = true;
        saveSystemVariables();
	}

    function onDebugLevelVerboseMenuItemClick(sender)
	{
        debugLevel = tkdlVerbose;
        if(typeof this.debugLevelVerboseMenuItem != "undefined")
            debugLevelVerboseMenuItem.checked = true;
        saveSystemVariables();
	}
    
	var logMode = false;
	var logPad = void;
	var cmdLog = [];
	var imageLog = [];
	var soundLog = [];
	var voiceLog = [];

    function error(msg) {
        if (debugLevel >= tkdlSimple) dm(msg);
    }
    
	function errorLine(target, msg) {
		var info = getCurrentInfo();
		var filename = info.file;
		var line     = info.line;
		var shortfn  = Storages.extractStorageName(filename);
		var fullfn   = filename != "" ? Storages.getPlacedPath(filename) : void;
		if (fullfn != "") {
			var exename  = System.exePath.toLowerCase();
			if (fullfn.substring(0,exename.length).toLowerCase() == exename) {
				fullfn = fullfn.substring(exename.length);
			}
		}
		callHook("onErrorLineHook", target, msg, filename, line);
		var shortmsg = "%s:%d: %s".sprintf(shortfn, line, msg);
		if (debugLevel >= tkdlSimple) dm(shortmsg);
		if (logMode && target !== void) {
			var fullmsg  = "%s:%d: %s".sprintf(fullfn, line, msg);
			target.add(fullmsg);
			if (logPad !== void) with (logPad) {
				var stat = "Latest log at the top";
				.text = "" if (.statusText != stat);
				.text = shortmsg + "\n" +.text;
				.statusText = stat;
				.visible = true;
			}
		}
    }

    /**
	 * Unknown command
     */
	function errorCmd(msg) {
		errorLine(cmdLog, msg);
    }

	
    /**
     * When image file cannot be loaded
     */
    function errorImage(msg) {
        errorLine(imageLog, msg);
    }

    /**
     * When sound file cannot be loaded
     */
    function errorSound(msg) {
        errorLine(soundLog, msg);
    }

    /**
     * When voice file cannot be loaded
     */
    function errorVoice(msg) {
        errorLine(voiceLog, msg);
    }

    /**
     * Initialize logs
     */
    function initLog() {
		cmdLog.clear();
		imageLog.clear();
        soundLog.clear();
        voiceLog.clear();
    }
	function initLogPad(pos = false, noclear = false) {
		if (logPad === void) {
			logPad = new Pad();
			with (logPad) {
				.borderStyle = bsSizeToolWin;
				.color = 0;
				.fontColor = 0xFFFFFF;
				.fontFace = "MS Gothic"; //chDefaultFace;
				.readOnly = false;
				.wordWrap = true;
				.height = 10;
				.title = "KAGEX Log";
				if (typeof .registerExEvent == "Object" &&
					typeof this.chDebugLogMenuItem == "Object") {
					.onClose = function {
						if (!isvalid this) return;
						onChDebugLogMenuItemClick(chDebugLogMenuItem) if (logMode);
					} incontextof this;
					.registerExEvent();
				}
			}
		}
		with (logPad) {
			if (pos) {
				.width  = width;
				.height = scHeight\2;
				.left   = left;
				.top    = top + height;
			} else {
				.width = scWidth;
				.height = scHeight\2;
			}
			.text = "" if (!noclear);
			.statusText = "Latest log at the top";
			.visible = true;
		}
	}

    /**
     * Output log
     */
    function outputLog() {
        if (logMode) {
			cmdLog.save(Debug.logLocation + "/cmderror.log");
			imageLog.save(Debug.logLocation + "/imageerror.log");
			soundLog.save(Debug.logLocation + "/sounderror.log");
			voiceLog.save(Debug.logLocation + "/voiceerror.log");
			if (logPad !== void) with (logPad) {
				.text = (
					"■Command Errors\n" + cmdLog  .join("\n") + "\n\n" +
					"■Image Errors\n" + imageLog.join("\n") + "\n\n" +
					"■Sound Errors\n" + soundLog.join("\n") + "\n\n" +
					"■Voice Errors\n"   + voiceLog.join("\n") + "\n\n");
				.statusText = "Output Result";
				.visible = true;
			}
			initLog();
        }
    }

    /**
     * Display Dialog
     */
	var _errorInformMessageMap = %[
	savefail: "Could not save to file (File cannot be opened or is write-protected)",
	loadfail:  "Attempted to load data from a different system",
	loadforce:  %[ message:"Save data ID mismatch, but forcing load due to debug mode", caption:"Warning" ],
	loadexception: %[ exp:function(mes) { return @"Could not load bookmark, data is corrupted, or it's a different format (${mes})"; } ],
	initexception: %[ exp:function(mes) { return @"Could not load system variables or they are corrupted (${mes})\nStarting with full initialization."; } ],
	savemydoc: %[ message:"No write permission. Saving data under My Documents.", caption:"Information" ],
	readonly:  %[ message:"No write permission. Running in Read-Only Mode.",          caption:"Warning" ],
		];
	function errorInform(tag, *) {
		if (tag == "" || _errorInformMessageMap[tag] == "") return;
		var msg = _errorInformMessageMap[tag];
		var cap = "Error";
		if (typeof msg == "Object") with (msg) {
			cap = .caption if (typeof .caption != "undefined");
			msg = .exp(*)  if (typeof .exp     != "undefined");
			msg = .message if (typeof .message != "undefined");
		}
		internalErrorInform(msg, cap);
	}
	function internalErrorInform(msg, cap) {
		System.inform(msg, cap + ":" + System.title);
	}

    // -------------------------------------------------------------

	// Get runtime information
	// Runtime storage, line number, label, line string, etc.
	function getCurrentInfo() {
		var info = forEachFunctionHook("getCurrentInfo");
		if (info === void) {
			with (mainConductor) {
				info = %[
				file:.curStorage,
				line:.curLine,
				label:.runLabel,
				lineStr:.runLineStr,
					];
			}
		}
		return info;
	}
	
    /**
     * Update debug window display content
     */
	function updateDebugInfo() {
		if (_debugwin !== void && debugwin.visible) {
			var info = getCurrentInfo();
			var filename = info.file;
			var exename  = System.exePath;
			if (filename.substring(0,exename.length) == exename) {
				filename = filename.substring(exename.length);
			}
			var voicename = "";
			if (hasCurrentVoice) {
				for (var i=0;i<currentVoice.count;i++) {
					voicename += currentVoice[i].name + ":" + currentVoice[i].voice + ",";
				}
			}
			var title = "%06d:%s %s %s".sprintf(info.line, filename, info.label, voicename);
			debugwin.fillRect(0, 0, debugwin.width, debugwin.height, 0xa0000000);
			debugwin.drawText(10, 10, title , 0xffffff);
			debugwin.drawText(10, 30, info.lineStr, 0xffffff);
        }
		if (skipNoDispWin !== void) {
			skipNoDispWin.visible = true;
			var title = "Skipping to next choice: %s".sprintf(getSkipNoDispText());
			skipNoDispWin.fillRect(0, 0, skipNoDispWin.width, skipNoDispWin.height, 0xa0000000);
			skipNoDispWin.drawText(10, 10, title , 0xffffff);
		}
    }
	function getSkipNoDispText() { return currentPageName; }

    /**
     * Toggle debug window ON/OFF
     */
    function onDebugWinMenuItemClick(sender)
	{
        debugwin.visible = !debugwin.visible;
		callHook("onDebugWinVisibleChanged", debugwin.visible);
        if(typeof this.debugWinMenuItem != "undefined")
            debugWinMenuItem.checked = debugwin.visible;
        if (debugwin.visible) {
            updateDebugInfo();
        }
        saveSystemVariables();
	}

    // -------------------------------------------------------------

	// External control
	function onMessageReceived(key, mes) {
		if (key == System.title) {
			Debug.notice("External control message received: "+mes);
			distributeReceivedMessage(mes);
		}
	}
	var     _debugSendMessageArgumentApplyed;
	function debugSendMessageArgumentApply() {
		var mes = System.getArgument("-sendmessage");
		if (   !_debugSendMessageArgumentApplyed && mes != "") {
			/**/_debugSendMessageArgumentApplyed = true;
			Debug.notice("Control message received from startup option: "+mes);
			distributeReceivedMessage(mes);
		}
	}
	function distributeReceivedMessage(mes) {
		callHook("onMessageReceivedHook", mes);
	}

    
    // -------------------------------------------------------------
    
    // All-seen mode (Used only as a flag by some systems)
    var allseen = false;

    // -------------------------------------------------------------

	/**
	 * System Reset (Incomplete)
	 */
	function resetAll() {
		forEachEventHook('onResetAll');

		(Dictionary.clear incontextof pflags)();
		if (startAnchorEnabled) {
			goToStart();
			startAnchorEnabled = true;
		} else  {
			clearLayers(fore);
			restoreFlags();
		}

		stablePosibility = true;
		cancelSkip();
		inSleep = true;
		notifyStable();

		conductor.sleep();
		conductor.interrupt();

		setMenuAccessibleAll();
	}

	// -------------------------------------------------------------
	// Squirrel control system
	// -------------------------------------------------------------
	
	var prevSqTick;
	var squirrelThreads = [];

	// Find thread from thread list
	function findSqThread(name) {
		for (var i=squirrelThreads.count-1;i>=0;i--) {
			var thinfo = squirrelThreads[i];
			if (thinfo.name == name) {
				return thinfo.th;
			}
		}
	}
	
	/**
	 * Execute squirrel thread
	 * @param name Name specification
	 * @param script Script to load
	 * @param elm Argument info
	 */
	function forkSquirrel(name, script, elm) {
		Plugins.link("squirrel.dll") if (typeof global.Scripts.forkStorageSQ != "Object");
		var th = Scripts.forkStorageSQ(script, kag, elm);
		squirrelThreads.add(%[name:name, th:th]);
		if (Scripts.getThreadCountSQ() == 1) {
			System.addContinuousHandler(driveSquirrel);
			prevSqTick = System.getTickCount();
		}
		return th;
	}

	// Terminate specified squirrel thread
	// Actual deletion occurs during next execution
	function stopSquirrel(name) {
		var th = findSqThread(name);
		if (th !== void) {
			th.exit(-1);
		}
	}

	// Terminate all squirrel threads
	function stopAllSquirrel() {
		for (var i=squirrelThreads.count-1;i>=0;i--) {
			var thinfo = squirrelThreads[i];
			thinfo.th.exit(-1);
		}
		squirrelThreads.clear();
	}
	
	// Squirrel thread drive process
	function driveSquirrel(tick) {
		if (Scripts.driveSQ(tick - prevSqTick, onSquirrelThreadDone) == 0) {
			System.removeContinuousHandler(driveSquirrel);
		}
		prevSqTick = tick;
	}
	
	/**
	 * Processing called when squirrel thread execution ends
	 */
	function onSquirrelThreadDone(th) {
		for (var i=squirrelThreads.count-1;i>=0;i--) {
			var thinfo = squirrelThreads[i];
			if (Scripts.compareSQ(th, thinfo.th) == 0) {
				// Trigger for specific thread end
				trigger("sqthread:" + thinfo.name);
				squirrelThreads.erase(i);
			}
		}
		// All threads end
		if (squirrelThreads.count == 0) {
			trigger("sqthread");
		}
	}

	/**
	 * Wait for squirrel thread execution
	 */
	function waitSingleSquirrel(target, canskip=false, wait=0) {
		var th = findSqThread(target);
		if (th === void || th.getStatus() == 0) {
			return 0;
		}
		var name = 'sqthread:' + target;
		if((canskip !== void && +canskip) && clickSkipEnabled)
		{
			// If skippable
			if(skipMode)
			{
				// Skipping in progress
				stopSquirrel(target);
				return 0; // Stop automatic move and return immediately
			}
			conductor.wait(%[
				click : function (target)
				{
                    updateBeforeCh = 1;
					stopSquirrel(target);
				} incontextof this,
				'click_arg' => target, // Argument for handler
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		else
		{
			conductor.wait(%[
				name => function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				name + "_arg" => wait
				]);
		}
		return -2;
	}

	/**
	 * Wait for all squirrel thread executions
	 */
	function waitAllSquirrel(canskip=false, wait=0)	{
		if (squirrelThreads.count == 0) return 0;
		if((canskip !== void && +canskip) && clickSkipEnabled)
		{
			if(skipMode)
			{
				stopAllSquirrel();
				return 0;
			}
			conductor.wait(%[
				click : function
				{
					updateBeforeCh = 1;
					stopAllSquirrel();
				} incontextof this,
			    sqthread : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				sqthread_arg : wait
				]);
		}
		else
		{
			conductor.wait(%[
				sqthread : function(arg)
				{
					updateBeforeCh = 1;
					return arg;
				} incontextof this,
				sqthread_arg : wait
				]);
		}
		return -2;
	}
	
	// Wait for squirrel execution
	function waitSquirrel(elm) {
		if (elm.name !== void) {
			return waitSingleSquirrel(elm.name, elm.canskip, +elm.wait);
		} else {
			return waitAllSquirrel(elm.canskip, +elm.wait);
		}
		return 0;
	}

	// -------------------------------------------------------------
	// Motion Panel
	// -------------------------------------------------------------


}


// End TJS Script
"
END_OF_TJS_SCRIPT
# "; /*

# Perl script to regenerate variables that should be copied via assign

open FH, "MainWindow.tjs" or die;
undef($/);
$content = <FH>;

$list_store = '';
$list_restore = '';
while($content =~ /\/\*C\*\/var\s+(\w+)/gs)
{
	$list_store .= "\t\tf.$1 = $1;\n";
	$list_restore .= "\t\t$1 = f.$1 if f.$1 !== void;\n";
}

$content =~
s/\t\t\/\/ \[start_store_vars\]\n.*?\t\t\/\/ \[end_store_vars\]/\t\t\/\/ \[start_store_vars\]\n$list_store\t\t\/\/ \[end_store_vars\]/s;
$content =~
s/\t\t\/\/ \[start_restore_vars\]\n.*?\t\t\/\/ \[end_restore_vars\]/\t\t\/\/ \[start_restore_vars\]\n$list_restore\t\t\/\/ \[end_restore_vars\]/s;

open FH, ">MainWindow.tjs" or die;
print FH $content;


# */
