			autoLabelCount++;
			storeAutoLabel();
		}
		//dm("exit condition:" + elm.eval);
		if (elm.eval == "" || Scripts.eval(elm.eval)) {
			if (elm.exp !== void) {
				Scripts.eval(elm.exp);
			}
			if (elm.storage !== void || elm.target !== void) {
				process(elm.storage, elm.target);
				return 0;
			} else {
				goToStart();
