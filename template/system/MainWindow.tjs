            if (selectPrevSkipMode == SKIP_STOP) {

                skipMode = SKIP_STOP;

				_tempAllskip  = selectPrevTempSkip;

            } else if (selectPrevSkipMode == SKIP_FAST) {

                if (getKeyState(VK_CONTROL)) {

                    skipMode = SKIP_FAST;

				}

            }

        }

        setMenuAccessibleAll();

    }



	function invokeSelectLayerSetSelProcessLock() {

		if (selectShowing    && typeof selectLayer   .setSelProcessLock == "Object")

			/**/                       selectLayer   .setSelProcessLock(...);

		if (mapSelectShowing && typeof mapSelectLayer.setSelProcessLock == "Object")

			/**/                       mapSelectLayer.setSelProcessLock(...);

	}





    //------------------------------------------------------- Map Choices --



