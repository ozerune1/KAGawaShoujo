	function showLineBreak(elm)
	{
		// Release delay after line processing
		addFastTag("extractdelay", %[label:"kl" + (++keywaitLabelCount)]);

		// Display line break glyph in current message layer
		stablePosibility = true;
		if(canIgnoreL())
		{
