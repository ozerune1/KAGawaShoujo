    //------------------------------------------------------- Branches within Scenario --



	/**

	 * Add branch

	 */

    function addBranch(elm) {

		if (f.branchInfos == void) {

			f.branchInfos = [];

		}

		delete f.branchDoneTarget;

		var e = %[];

		(Dictionary.assign incontextof e)(elm,false);

		f.branchInfos.add(e);

		return 0;

    }



	/**

	 * Execute branch

	 */

	function doBranch(elm) {

		f.branchDoneTarget  = elm.target  if elm.target  !== void;

		for (var i=0;i<f.branchInfos.count;i++) {

			var elm = f.branchInfos[i];

			if (elm.target !== void && (elm.eval === void || elm.eval == "" || Scripts.eval(elm.eval))) {

				if (elm.exp !== void) {

					Scripts.eval(elm.exp);

				}

				insertTag("next", %[target:elm.target]);

				break;

			}

		}

		delete f.branchInfos;

		return 0;

    }



	/**

	 * End branch

	 */

	function doneBranch(elm) {

		if (f.branchDoneTarget != "") {

			// Branch

			insertTag("next", %[target:f.branchDoneTarget]);

		} else {

			// Force stop

			return tagHandlers.s(elm);

		}

        return 0;

    }

	

    //------------------------------------------------------- Transition Special Layer --



    function hideTransLayer() {

        if (_transLayer !== void) {

            transLayer.stop();

            transShowing = false;

        }

    }

    

    function layerTransBegin(elm)

	{

		hideTransLayer();

		if (elm.time === void) { elm.time = 1000; }

		if (elm.type === void) { elm.type = "trans"; }

		elm.time *= effectspeed;

		var waitParam  = %[];

		if((elm.canskip === void || +elm.canskip) && clickSkipEnabled) {

			if(skipMode && effectspeed == 0) {

				return 0; // Return immediately

            }

            waitParam.click = function() {hideTransLayer();} incontextof this;

		}

		waitParam.layertrans = function(arg) { return arg; } incontextof this;

		waitParam.layertrans_arg = +elm.wait;

		transLayer.start(elm);

		flipStart();

		transShowing = true;

		conductor.wait(waitParam);

        return -2;

	}



    function layerTransEnd(elm) {

        if (!transShowing) {

            return 0;

        }

        var waitParam  = %[];

		if((elm.canskip === void || +elm.canskip) && clickSkipEnabled) {

			if(skipMode && effectspeed == 0) {

				hideTransLayer();

				return 0; // Return immediately

            }

            waitParam.click = function() {hideTransLayer();} incontextof this;

        }

		waitParam.layertrans = function(arg) {hideTransLayer();return arg;} incontextof this;

		waitParam.layertrans_arg = +elm.wait;

		transLayer.start(elm, true);

		flipStart();

		conductor.wait(waitParam);

        return -2;

    }



    //------------------------------------------------------- Blackout Transition --



	var btLayer;



	function hideBlackLayer() {

		if (btLayer !== void) {

			invalidate btLayer;

			btLayer = void;

        }

    }

	

	// Blackout transition open

	function blackTransBegin(elm) {

		hideBlackLayer();

		var waitParam  = %[];

		if((elm.canskip === void || +elm.canskip) && clickSkipEnabled) {

			if(skipMode && effectpeed==0) {

				updateBeforeCh = 1;

				return 0;

			}

			waitParam.click = function() {

				stopAllTransitions(true);

				hideBlackLayer();

				updateBeforeCh = 1;

			} incontextof this;

		}

		btLayer = new Layer(this, back.base);

		with (btLayer) {

			.width  = exWidth;

			.height = exHeight;

			.fillRect(0,0,.width,.height, 0xff000000 | +elm.color);

			.visible = true;

			.hitThreshold = 256;

		}

		elm.children = true;

		if (elm.method === void) {

			elm.method = "crossfade";

		}

		//forEachEventHook('onPreTransition');

		beginTransition(kag.fore.base, elm);

		waitParam.trans = function(arg) {updateBeforeCh = 1;return arg;} incontextof this;

		waitParam.trans_arg = +elm.wait;

		conductor.wait(waitParam);

		return -2;

    }

	

	// Blackout transition close

	function blackTransEnd(elm) {

		stopAllTransitions(true);

		if (btLayer === void) {

			updateBeforeCh = 1;

			return 0;

		}

		var waitParam  = %[];

		if((elm.canskip === void || +elm.canskip) && clickSkipEnabled) {

			if(skipMode && effectpeed==0) {

				hideBlackLayer();

				updateBeforeCh = 1;

				return 0;

			}

			waitParam.click = function() {

				stopAllTransitions(true);

				hideBlackLayer();updateBeforeCh = 1;

			} incontextof this;

		}

		backupLayer(elm, true);

		elm.children = true;

		if (elm.method === void) {

			elm.method = "crossfade";

		}

		forEachEventHook('onPreTransition');

		beginTransition(kag.fore.base, elm);

		waitParam.trans = function(arg) {hideBlackLayer();updateBeforeCh = 1;return arg;} incontextof this;

		waitParam.trans_arg = +elm.wait;

		conductor.wait(waitParam);

		return -2;

    }

	

	//------------------------------------------------------- Panel Processing --



	// For panel

	var panelLayer;

	var panelShowing = false;

	var panelLayerAbsolute = 8000000;

