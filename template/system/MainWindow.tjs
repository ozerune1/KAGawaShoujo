	p : function(elm)
	{
        // Auto-label mode is valid in the p tag

		if (!elm.nosave && !(erAfterPage && noErOnce)) {
			// Do not auto-save if clearing after page break is disabled
			// This is meaningful in pre-processing parts like choices
			setAutoLabel();
		}

        // Release auto-indent
        if (autoIndent) {
            tagHandlers.endindent(%[ pagebreak:true ]);
        }

        // Wait for page click
		if (!skipNoDisp) {
			if(historyWriteEnabled) historyLayer.reline(true);
		}
		var ret = showPageBreak(elm);

		// Tag called after the page ends
		insertTag("afterpage");

		// Forcefully insert a clear after waiting for page
        if (erAfterPage) {
			if (!noErOnce) {
				insertTag("er", %[]);
            }
            noErOnce = false;
        }
		
		// Cancellation of delayed execution
		insertTag("delaydone");
		
        return ret;

	} incontextof this,

	p2 : function(elm)
	{
		return showPageBreak(elm);
	} incontextof this,
				  
