		{
			conductor.wait(%[
				name => function (arg) { notifyRun(); isWaitPeriodEvent = false; return arg; } incontextof this,
				name + "_arg" => +elm.wait
					]);
		}
		else
		{
			conductor.wait(%[
				'movieperiod'+id+'_'+perLoop => function (arg) { notifyRun(); isWaitPeriodEvent = false; return arg; } incontextof this,
				'movieperiod'+id+'_'+perLoop + "_arg" => +elm.wait,
				'movieperiod'+id+'_'+perPeriod => function (arg) { notifyRun(); isWaitPeriodEvent = false; return arg; } incontextof this,
				'movieperiod'+id+'_'+perPeriod + "_arg" => +elm.wait,
				'movieperiod'+id+'_'+perPrepare => function (arg) { notifyRun(); isWaitPeriodEvent = false; return arg; } incontextof this,
				'movieperiod'+id+'_'+perPrepare + "_arg" => +elm.wait,
				'movieperiod'+id+'_'+perSegLoop => function (arg) { notifyRun(); isWaitPeriodEvent = false; return arg; } incontextof this,
				'movieperiod'+id+'_'+perSegLoop + "_arg" => +elm.wait
				]);
		}
		notifyStable();
		return -2;
	}

	//--------------------------------------------------------- FireEffect Related --

	/**
	 * Stop all layer fire effects
	 */
	function stopAllLayerFires() {
		stopAllGenericFlipsOneClass("fire");
	}

	//--------------------------------------------------------- Generic Flip Related --

	var genericFlipsInstances = %[];
	var activeGenericFlips = [];
	function createGenericFlip(type, id) {
		var cls = GenericFlip.GetClass(type), obj;
		if (cls === void) return;
		try { obj = new cls(this); } catch { return; }
		obj.flipType = type;
		obj.flipID = (id != "") ? id : System.createUUID();
		var list = genericFlipsInstances[type];
		/**/list = genericFlipsInstances[type] = [] if (list === void);
		list.add(obj);
		activeGenericFlips.add(type) if (activeGenericFlips.find(type) < 0);
		flipStart();
		return obj;
	}
	function updateGenericFlips(now) {
		var  cnt = activeGenericFlips.count;
		if (!cnt) return false;
		var remove = false;
		for (var i = 0; i < cnt; i++) {
			var gft = activeGenericFlips[i], list, del = false;
			/**/list = genericFlipsInstances[gft] if (gft != "");
			if (list === void) del = true;
			else {
				del = !updateGenericFlipsOneClass(now, list, gft);
			}
			if (del) {
				activeGenericFlips[i] = void;
				remove = true;
			}
		}
		if (remove) activeGenericFlips.remove(void, true);
		return      activeGenericFlips.count > 0;
	}
	function updateGenericFlipsOneClass(now, list, gft) {
		var  cnt = list.count;
		if (!cnt) return false;
		var trig = GenericFlip.GetTrigger(gft);
		for (var i  = cnt-1; i >= 0; i--) {
			var obj = list[i];
			if (obj === void || !obj.flipFrame(now)) {
				if (obj) {
					conductor.trigger(trig + obj) if (trig != "");
					invalidate obj;
				}
				list.erase(i);
			}
		}
		cnt = list.count;
		conductor.trigger(trig) if (!cnt && trig != "");
		return cnt > 0;
	}
	function stopAllGenericFlips() {
		for (var i  = activeGenericFlips.count-1; i >= 0; i--)
			stopAllGenericFlipsOneClass(activeGenericFlips[i]);
	}
	function stopAllGenericFlipsOneClass(gft) {
		if (gft == "") return;
		var list = genericFlipsInstances[gft];
		if (list === void) return;
		for (var i  = list.count-1; i >= 0; i--) {
			var obj = list[i];
			/**/obj.flipStop() if (obj !== void);
		}
	}
	function getGenericFlipsInstanceCount(gft) {
		if (gft != "") {
			var list = genericFlipsInstances[gft];
			return (list !== void) ? list.count : 0;
		} else {
			var ret = 0;
			for (var i = activeGenericFlips.count-1; i >= 0; i--)
				try { ret += genericFlipsInstances[activeGenericFlips[i]].count; } catch {}
			return ret;
		}
	}
	function findGenericFlipsInstance(gft, id) {
		if (gft == "") {
			for (var tag, i = activeGenericFlips.count-1; i >= 0; i--) {
				gft = activeGenericFlips[i];
				if (gft == "") continue;
				var r = findGenericFlipsInstance(gft);
				if (r !== void) return r;
			}
		} else {
			var list = genericFlipsInstances[gft];
			if (list === void) return;
			for (var i = list.count-1; i >= 0; i--) {
				if (list[i] !== void && list[i].flipID == id) return list[i];
			}
		}
	}

	// ------------------------------------------------------ Clear All Layers

	/**
	 * Clear all layers
	 */
	function clearLayers(base) {
		
		base.base.freeImage();
        for(var i = base.layers.count-1; i >= 0; i--) {
			base.layers[i].freeImage();
            base.layers[i].visible = false;
        }
        for(var i = base.messages.count-1; i >= 0; i--) {
            base.messages[i].clear(true);
            base.messages[i].visible = false;
        }
        // Clear choice windows
		hideSelect();
		hideMapSelect();
		hideTransLayer();
		hideBlackLayer();
		hidePanel();
		forEachEventHook('onClear',,base);
		setMenuAccessibleAll();
	}
	
	// ------------------------------------------------------ Auto Message Clear Setting

    var erAfterPage; // Clear screen immediately after page break
	
    /**
	 * @param erAfterPage Clear screen immediately after page wait
	 */
	function setErAfterPage(erAfterPage) {
		this.erAfterPage = erAfterPage;
    }

    // ------------------------------------------------------ Special Line Break Control Mode
	
    var lineMode;    // Line processing mode
    var crAfterName; // Insert line break after name
    var noCrOnce;    // Skip line break processing once
    var noErOnce;    // Skip screen clear processing once
	var autoIndent;  // Auto-indent on 「 or 『

	// Bracket list for auto-indent (order must match Begin/End)
	var autoIndentBeginCharacters = "「『（‘“〔［｛〈《";
	var autoIndentEndCharacters   = "」』）’”〕］｝〉》";

	var indentLevel; // Count for 「
	var indentCharacter; // Character used for indent

    var afterPage;   // Immediately after page break
	var doLine;        // Instruction to execute input wait
	var emptyLine;     // Line still empty
	var commandLine;   // Line where command was executed
    var prevEmptyLine; // Previous empty line state

    var nameMode;    // Name processing mode
    var afterName;   // Immediately after name processing
    var nameStr;     // Current name
    var nameDisp;    // Current display name
    
    /**
     * @param lineMode
     * 0: Normal
     * 1: [p] by line
     * 2: [l] by line, [p] manual
     * 3: [l] by line, [p] on empty line
     * 4: Ignore line breaks. [p] on empty line
     * 5: Line break is [r]. [p] on empty line
     */
    function setLineMode(lineMode) {
		if (lineMode == "none" || lineMode == "") {
			//dm("Line Mode: None");
			mainConductor.ignoreCR = global.ignoreCR;
			afterPage = true;
			doLine = false;
            emptyLine = true;
			commandLine = false;
			prevEmptyLine = true;
			this.lineMode = LINEMODE_NONE;
        } else if (lineMode == "page") {
            //dm("Line Mode: page");
            mainConductor.ignoreCR  = false;
			afterPage = true;
			doLine = false;
            emptyLine = true;
			commandLine = false;
            prevEmptyLine = true;
            this.lineMode = LINEMODE_PAGE;
        } else if (lineMode == "line") {
            //dm("Line Mode: line");
            mainConductor.ignoreCR  = false;
            afterPage = true;
			doLine = false;
            emptyLine = true;
			commandLine = false;
            prevEmptyLine = true;
			this.lineMode = LINEMODE_LINE;
        } else if (lineMode == "vn") {
            //dm("Line Mode: vn");
            mainConductor.ignoreCR  = false;
            afterPage = true;
			doLine = false;
            emptyLine = true;
			commandLine = false;
            prevEmptyLine = true;
            this.lineMode = LINEMODE_VN;
        } else if (lineMode == "tex") {
            //dm("Line Mode: tex");
            mainConductor.ignoreCR  = false;
            afterPage = true;
			doLine = false;
            emptyLine = true;
			commandLine = false;
            prevEmptyLine = true;
            this.lineMode = LINEMODE_TEX;
        } else if (lineMode == "free") {
            //dm("Line Mode: free");
            mainConductor.ignoreCR  = false;
            afterPage = true;
			doLine = false;
            emptyLine = true;
			commandLine = false;
            prevEmptyLine = true;
            this.lineMode = LINEMODE_FREE;
        }
    }

    /**
     * @param crAfterName Whether to insert line break after name
     */
    function setCrAfterName(crAfterName) {
        this.crAfterName = crAfterName;
        afterName = false;
    }

    /**
     * @param autoIndent Auto-indent processing for 「『 immediately after name
     */
    function setAutoIndent(autoIndent) {
        this.autoIndent = autoIndent;
    }

    /**
     * Read status processing for auto-label mode
     */
	function storeAutoLabel() {
		if (autoLabelMode) {
			if (autoLabelCurrentRecordName != "") {
				if (sflags[autoLabelCurrentRecordName] === void ||
					sflags[autoLabelCurrentRecordName] < autoLabelCount) {
					sflags[autoLabelCurrentRecordName] = autoLabelCount;
					setUserSpeed(); // Reflect userCh2ndSpeed
					callHook("onStoreAutoLabelUpdate");
				}
            }
        }
    }

    /**
     * Auto-labeling setting
     */
    function setAutoLabel() {
		if (autoLabelMode && !usingExtraConductor) {
			// Interrupt conductor with auto-label processing
            insertTag("autolabel");
        }
    }

	/**
	 * Check to stop unread skip
	 */
	function checkAutoSkip() {
		if (autoLabelMode && autoLabelType == 1) {
			if(!(allskip || getCurrentRead()) && skipMode < SKIP_FAST) {
				cancelSkip(); // Stop skip if unread
			}
		}
	}

	/**
	 * Execute auto-label processing
	 */
	function doAutoLabel() {
		if (autoLabelMode) {
			// Special tag for auto-label processing
			// Not called from normal KAG.
			// Pseudo-inserted at start of line via page break processing.
			switch (autoLabelType) {
			case 0:
				// Save via indirect label method
				conductor.callLabel("");
				conductor.loadScenario("autolabel.ks");
				conductor.goToLabel("*autoLabelLabel");
				break;
			case 1:
				// Save processing in line-specific mode
				pushHistoryOfStore();
				storeFlags(true);
				storeLabelPassed = true;
				checkAutoSkip();
				setMenuAccessibleAll();
				break;
			}
		}
	}

	/**
	 * Add specified tag to execution queue / Interrupt execution next time
	 */
	function addTag()        { conductor.enqueueTag(    internalCopyTag(...)); }
	function insertTag()     { conductor.   pushTag(    internalCopyTag(...)); }

	/**
	 * High priority tag registration (Use caution: can disrupt behavior if used outside self-expansion)
	 */
	function addFastTag()    { conductor.enqueueFastTag(internalCopyTag(...)); }
	function insertFastTag() { conductor.   pushFastTag(internalCopyTag(...)); }

	function internalCopyTag(name, elm, add) {
		var e = %[];
		(Dictionary.assign incontextof e)(elm, false) if (elm !== void);
		e.tagname = name if name !== void;
		(Dictionary.assign incontextof e)(add, false) if (add !== void);
		return e;
	}

	/**
	 * Add tag (for parsing process)
	 */
	function addParseTag(cd, name, elm) {
        var e = %[];
        if (elm !== void) {
            (Dictionary.assign incontextof e)(elm, false);
        }
        e.tagname = name if name !== void;
		cd.pendings.add(e);
    }
	
	/**
	 * Parse parsing command
	 */
	function parseParse(cd, elm) {
		clearVoiceMap();
		if (elm.base !== void) {
			voiceBase = elm.base;
		}
		if (elm.voice !== void) {
			voiceDefault = +elm.voice;
		}
		addParseTag(cd, "parse");
    }

	// ------------------------------------------------
	// For Voice Processing
	// ------------------------------------------------

	var voiceBase = "";
	var voiceDefault;
	var voiceMap = %[];
	var nextVoiceList = [];
	
	function clearVoiceMap() {
		//dm("Voice map cleared");
		nextVoiceList.clear();
		(Dictionary.clear incontextof voiceMap)();
	}

	function storeVoiceMap(f) {
		f.voiceBase = voiceBase;
		f.voiceDefault = voiceDefault;
		var map = f.voiceMap = %[];
		var names = [];
		names.assign(voiceMap);
		var count = names.count;
		for (var i=0;i<count;i+=2) {
			var name  = names[i];
			var value = names[i+1];
			var info = %[];
			(Dictionary.assign incontextof info)(value);
			//dm("Stored value:" + name + ":" + value.voice);
			map[name] = info;
		}
	}

	function restoreVoiceMap(f) {
		voiceBase = f.voiceBase;
		voiceDefault = f.voiceDefault;
		clearVoiceMap();
		if (f.voiceMap !== void) {
			var names = [];
			names.assign(f.voiceMap);
			var count = names.count;
			for (var i=0;i<count;i+=2) {
				var name  = names[i];
				var value = names[i+1];
				var info = %[];
				(Dictionary.assign incontextof info)(value);
				//dm("Restored value:" + name + ":" + value.voice);
				voiceMap[name] = info;
			}
		}
	}
	
	var reNumber = new RegExp("^[1-9][0-9]*$");

	/**
	 * Voice specification
	 */
	function setVoice(name, voice, elm) {
		var info = voiceMap[name];
		if (info == void) {
			info = %[];
			voiceMap[name] = info;
		}
		if (voice.charAt(0) == "@") {
			if (info.voice !== void) {
				info.voice += +voice.substr(1);
			} else {
				info.voice = +voice.substr(1);
			}
		} else if (voice == "clear") {
			delete info.strVoice;
			delete info.voice;
			delete info.incVoice;
		} else if (voice == "dec") {
			if (info.voice !== void) {
				info.voice--;
			}
		} else if (voice == "count" || voice == "inc") {
			if (info.voice !== void) {
				info.voice++;
			}
		} else if (voice == "ignore") {
			info.strVoice = "ignore";
		} else if (reNumber.test(voice) || voice == "0") {
			// If numerical specification
			if (elm.once || elm.replace) {
				info.strVoice = +voice;
			} else {
				info.voice = +voice;
			}
		} else if (voice.length > 0) {
			info.strVoice = voice;
		}
		info.incVoice = elm.incvoice || elm.replace;
		info.noplayvoice = elm.noplayvoice;
		//dm("Voice set:%s:%s:%s".sprintf(name, info.voice, info.strVoice));
	}

	/**
	 * Returns current voice info for specified character
	 * @param name character name
	 * @return voice filename
	 */
	function getVoice(name) {
		if (name == "") return;
		//dm("Voice retrieval process:" + name);
		var info = voiceMap[name];
		if (info == void) {
			if (voiceDefault !== void) {
				info = %[];
				voiceMap[name] = info;
				info.voice = voiceDefault;
			}
		}
		var voice;
		if (info != void) {
			if (info.strVoice !== void) {
				if (info.strVoice != "ignore") {
					voice = info.strVoice;
				}
				info.strVoice = void;
			} else if (info.voice !== void) {
				voice = info.voice;
				info.incVoice = true;
			}
			if (info.incVoice) {
				if (info.voice >= 0) {
					info.voice++;
				}
				info.incVoice = void;
			}
			//dm("Voice retrieved:%s:%s".sprintf(name, voice));
		}
		return voice;
	}

	function setNextVoice(name) {
		var voice = getVoice(name);
		if (voice !== void) {
			var info = voiceMap[name];
			nextVoiceList.add(%[name:name, voice:voice, noplayvoice:info?info.noplayvoice:void]);
		}
	}

	// ----------------------------------------------------------------

	// Treated as voice commands
	var voiceCmds = %[ tagname:true, replace:true, once:true, entry:true ];
	
	function parseVoice(cd, elm) {
		var names = [];
		names.assign(elm);
		for (var i=0;i<names.count;i+=2) {
			var name  = names[i];
			var value = names[i+1];
			if (voiceCmds[name] !== void) {
				continue;
			}
			if (name == "base") {
				voiceBase = value;
				continue;
			} else if (name == "default") {
				voiceDefault = value;
				continue;
			}
			setVoice(name, value, elm);
		}
	}

	function parseNextVoice(cd, elm) {
		var names = [];
		names.assign(elm);
		for (var i=0;i<names.count;i+=2) {
			var name  = names[i];
			setNextVoice(elm.name);
		}
	}

	// -------------------------------------------------
	
	function lineCheck(cd) {
		// Line mode processing at start of line
		// instructions exist
		if (doLine) {
			parseL(cd);
			doLine = false;
		}
	}
	
	function emptyCheck(cd) {
		// Text clear processing
		switch (lineMode) {
		case LINEMODE_PAGE:
			break;
		case LINEMODE_LINE:
		case LINEMODE_VN:
		case LINEMODE_FREE:
			if (afterPage) {
				afterPage = false;
			} else {
				if (!afterName && !skipNoDisp) {
					addParseTag(cd, "r");
				}
			}
			break;
		case LINEMODE_TEX: // tex
			if (afterPage) {
				afterPage = false;
			}
			break;
		}
		if (!afterName && (lineMode <= LINEMODE_LINE || prevEmptyLine)) {
			addParseTag(cd, "dispname");
			afterName = true;
			indentCharacter = void;
			indentLevel = 0;
		}
	}
	
	/**
	 * Parsing text
	 */
	function parseCh(cd, elm, isload) {

        // Special name display processing
        // Detect 【Character Name/Display Name】 and execute name display process
		if (nameMode > 0) {
            // Already in name display logic
            // emptyLine state impossible here
			if (elm.text == "】") {
				nameMode = 0;
				//dm("Name processing:" + nameStr + ":" + nameDisp);
				if (!isload) {
					setNextVoice(nameStr);
				}
				//dm("Name expansion:" + nameStr + " / " + nameDisp);
				if (nextVoiceList.count > 0) {
					var voices = nextVoiceList;
					nextVoiceList = [];
					addParseTag(cd, "dispname", %[name:nameStr, disp:nameDisp, voice:voices]);
				} else {
					addParseTag(cd, "dispname", %[name:nameStr, disp:nameDisp]);
				}
				afterName = true;
				indentCharacter = void;
				indentLevel = 0;
                return;
            } else {
				if (nameMode == 1) {
					if (elm.text == "/") {
						nameMode = 2;
                        return 0;
                    } else {
                        nameStr += elm.text;
                    }
                } else {
                    nameDisp += elm.text;
                }
            }
            return;
		} else if (emptyLine) {
			lineCheck(cd);
			if (elm.text == "【") {
				nameMode = 1;
				nameStr  = "";
				nameDisp = "";
				return;
			} 
			emptyCheck(cd);
        }

		// Auto-indent character check
		var indentBeginIdx = -1, indentEndIdx = -1;
		if (!skipNoDisp && autoIndent && elm.text != "") {
			var ch = ((string)elm.text).charAt(0);
			indentBeginIdx = autoIndentBeginCharacters.indexOf(ch);
			indentEndIdx   = autoIndentEndCharacters  .indexOf(ch);
		}

		// Character registration
		if (!skipNoDisp) {
			if (autoIndent < 0 && indentBeginIdx >= 0) {
				if (afterName || callHook("onPreIndentCheck", indentBeginIdx)) { // || (emptyLine && !indentLevel)) {
					addParseTag(cd, "preindent", elm);
				}
			}
			addParseTag(cd, "ch", elm);
		}
		emptyLine = false;
		afterPage = false;

		// Auto-indent processing
		if (indentBeginIdx >= 0) {
			if (afterName) {
				indentCharacter = autoIndentBeginCharacters.charAt(indentBeginIdx);
				addParseTag(cd, "indent");
			}
			indentLevel++;
		} else if (indentEndIdx >= 0) {
			if (indentLevel == 1) {
				var pair = autoIndentBeginCharacters.indexOf(indentCharacter);
				addParseTag(cd, "endindent") if (pair == indentEndIdx);
			}
			indentLevel--;
		}
		afterName = false;

        return;
    };

	/**
	 * Parsing line breaks
	 */
	function parseR(cd, elm)
	{
		if (!elm.eol) {
			// instruction exists
			if (doLine) {
				parseL(cd);
				doLine = false;
			}
			if (!skipNoDisp) {
				checkName(cd);
				addParseTag(cd, "r", elm);
			}
			return;
		}

		// Skip line break effect once
        if (noCrOnce) {
			noCrOnce = false;
			prevEmptyLine = emptyLine;
			emptyLine = true;
			commandLine = false;
			return 0;
        }

		nameMode = 0;
		if (crAfterName && afterName) {
			commandLine = false;
			return 0;
		}
		
		switch (lineMode) {
        case LINEMODE_PAGE:
			//dm("page: line break");
			if (emptyLine) {
				if (!commandLine) {
					prevEmptyLine = emptyLine;
				}
            } else {
				prevEmptyLine = emptyLine;
				emptyLine = true;
				if (!skipNoDisp) {
					addParseTag(cd, "p", elm);
				} else {
					checkAutoSkip();
					setAutoLabel();
					addParseTag(cd, "delaydone", elm);
					addParseTag(cd, "afterpage", elm);
				}
			}
            break;
        case LINEMODE_LINE:
            //dm("line: line break");
			if (emptyLine) {
				if (!commandLine) {
					prevEmptyLine = emptyLine;
				}
            } else {
				prevEmptyLine = emptyLine;
				emptyLine = true;
				parseL(cd);
			}
			break;
        case LINEMODE_VN:
            //dm("vn: line break");
            if (emptyLine) {
				if (!prevEmptyLine) {
					if (!commandLine) {
						// Page break on first empty line
						doLine = false;
						prevEmptyLine = emptyLine;
						parseP(cd, elm);
					}
				} else {
					// Ignore other empty lines
                    prevEmptyLine = emptyLine;
                }
            } else {
                // Ignore line break immediately after name
				prevEmptyLine = emptyLine;
				emptyLine = true;
				if (!skipNoDisp) {
					doLine = true;
				}
			}
			break;

        case LINEMODE_TEX:
        case LINEMODE_FREE:
            //dm("tex/free: line break");
            if (emptyLine) {
				if (!commandLine) {
					if (!prevEmptyLine) {
						// Page break on first empty line
						prevEmptyLine = emptyLine;
						parseP(cd, elm);
					} else {
						// Ignore other empty lines
						prevEmptyLine = emptyLine;
					}
				}
            } else {
                // Ignore line break immediately after name
				prevEmptyLine = emptyLine;
				emptyLine = true;
            }
        }
		commandLine = false;
        return 0;
	}

	function parseL(cd) {
		if (!skipNoDisp) {
			addParseTag(cd, "l", %[voicewait:true]);
			addParseTag(cd, "afterline");
		}
	}

	function parseL2(cd, elm) {
		addParseTag(cd, "l", elm);
	}
	
	/**
	 * Expanding p tag
	 */
    function parseP(cd, elm) {
		if (!skipNoDisp) {
			addParseTag(cd, "p", elm);
		} else {
			checkAutoSkip();
			setAutoLabel();
			addParseTag(cd, "delaydone", elm);
			addParseTag(cd, "afterpage", elm);
		}
		afterPage = true;
		emptyLine = true;
		commandLine = false;
		nameStr = "";
		nameDisp = "";
    }

	// Name check
	function checkName(cd) {
		if (emptyLine) {
			lineCheck(cd);
			emptyCheck(cd);
		}
		emptyLine = false;
		afterPage = false;
		afterName = false;
	}

	function parseRuby(cd, elm) {
		checkName(cd);
		if (!skipNoDisp) {
			addParseTag(cd, "ruby",elm);
		}
	}

	// Tag that acts as character but displays nothing
	function parseNul(cd, elm) {
		checkName(cd);
	}
	
	var textTags = %[
	ruby:parseRuby incontextof this,
	ch:parseCh incontextof this,
	nul:parseNul incontextof this,
	r:parseR incontextof this,
	p:parseP incontextof this,
	l:parseL2 incontextof this,
	nor: function(elm) { noCrOnce = true; return 0; } incontextof this,
	noer: function(elm) { noErOnce = true; return 0; } incontextof this,
		];
	
	var extractTags = %[
	parse:parseParse incontextof this,
	voice:parseVoice incontextof this,
	nextvoice:parseNextVoice incontextof this,
		];
	
    /*
     * Tag expansion process
     * Performs special tag expansion according to lineMode
     */
	function checkTagExtract(cd, elm, isload) {
		// Count labels for auto-save
		if (!isload && autoLabelMode && elm.tagname == "r" && elm.eol) {
			autoLabelCount++;
			storeAutoLabel();
		}
		// Expansion process
		if (lineMode != 0) {
			var func = textTags[elm.tagname];
			if (func !== void) {
				func(cd, elm, isload);
				return true;
			} else {
				// Execute instructions if they exist
				if (doLine) {
					parseL(cd);
					doLine = false;
				}
				commandLine = true;
				var func = extractTags[elm.tagname];
				if (func !== void) {
					func(cd, elm);
					return true;
				}
			}
        }
		// Special ruby processing
		var rb = checkRubyTag(elm.tagname);
		if (rb !== void) {
			checkName(cd);
			if (!skipNoDisp) {
				var len = rb.length, ruby = rb.ruby, text = rb.text;
				for (var i = 0; i < len; i++) {
					addParseTag(cd, "ruby", %[ text:ruby[i] ]) if (ruby[i] != "");
					addParseTag(cd, "ch",   %[ text:text[i] ]);
				}
			}
			return true;
		}
		return false;
	}
	// Delimiters for special ruby (expansion disabled if "")
	var RubySplitNormal   = ",";
	var RubySplitDivision = ",";
	var RubySplitSimple   = "'";

	// Check whether to expand ruby
	function checkRubyTag(tag) {
		var p, n = RubySplitNormal, s = RubySplitSimple;
		return (n != "" && (p = tag.indexOf(n)) > 0) ? extractRubyTag(    tag.substring(0,p),        tag.substring(p+1))
			:  (s != "" && (p = tag.indexOf(s)) > 0) ? %[ length:1, text:[tag.substring(0,p)], ruby:[tag.substring(p+1)] ] : void;
	}
	// Ruby expansion process
	function extractRubyTag(text, ruby) {
		var tlen = text.length;
		var rlen = ruby.length;
		var tdiv = [], rdiv = [];
		var ret  = %[ length:tlen, text:tdiv, ruby:rdiv ];
		// Populate text splits as is
		for (var i = 0; i < tlen; i++) tdiv.add(text.charAt(i));

		if (ruby != "" && RubySplitDivision != "" && ruby.indexOf(RubySplitDivision) >= 0) {
			// If multi-delimiter "," used
			var div = ruby.split(RubySplitDivision);
			if (div.count != tlen) {
				error("ex-ruby: Count mismatch: " + text + "/" + ruby);
			}
			rdiv.assign(div);
		} else if (tlen == 1) {
			// Indisputable if 1 character
			rdiv.add(ruby);
		} else if (rlen == tlen) {
			// Per-character assignment
			for (var i = 0; i < rlen; i++) rdiv.add(ruby.charAt(i));
		} else if (rlen == tlen * 2) {
			// Per-2-characters assignment
			for (var i = 0; i < tlen; i++) rdiv.add(ruby.substring(i*2,2));
		} else if (rlen > tlen) {
			// Ruby is longer
			// Ruby characters per text character
			var n = (int)(rlen / tlen);
			if (n < 2) {
				// If less than 2 characters
				var start = (int)((tlen - rlen/2)/2);
				var rubyshift = "";
				if ((tlen - rlen / 2) % 2 == 1) {
					// Shift if not divisible
					rubyshift = "   ";
				}
				for (var i = 0; i < start; i++) rdiv.add("");

				// Distribute evenly. Rough implementation.
				for(var i = 0; i < rlen; i+=2) {
					rdiv.add(rubyshift + ruby.substring(i,2));
				}
			} else {
				// Overlap since ruby is longer
				// Number of overflowing ruby characters
				var cnt = rlen - tlen * 2;
				var rubyshift = "";
				if (cnt % 2 == 1) {
					// Shift if not divisible
					rubyshift = " ";
				}
				cnt = (int)((cnt+1) / 2);
				var firstruby = ruby.substring(0,cnt+2);
				if (cnt > 0) firstruby += " ".repeat(cnt);
				rdiv.add(rubyshift + firstruby);

				var r = cnt+2;
				for (var i = 1; i < tlen-1; i++,r+=2) {
					rdiv.add(rubyshift + ruby.substring(r,2));
				}
				var lastruby = ruby.substring(r);
				cnt = lastruby.length - 2;
				if (cnt > 0) lastruby = " ".repeat(cnt) + lastruby;

				rdiv.add(rubyshift + lastruby);
			}
		} else {
			// Ruby is shorter
			// Characters per ruby character
			var n = (int)(tlen / rlen);
			var start = (int)((tlen - rlen * n) / 2);
			var rubyshift = "";
			if ((tlen - rlen * n) % 2 == 1) {
				// Shift if not divisible
				rubyshift = "   ";
			}
			for (var i = 0; i < start; i++) rdiv.add("");
			// Distribute evenly. Rough implementation.
			for(var i = 0; i < rlen; i++) {
				rdiv.add(rubyshift + ruby.charAt(i));
				for (var k = 1; k < n; k++) rdiv.add("");
			}
		}
		return ret;
	}

	// Special wait specification
	// Executes wait process if sync or wait specified
	function waitFunc(elm, func) {
		//dm("waitFunc call:" + elm.wait + ":" + elm.sync);
		if (elm.wait !== void || elm.sync !== void) {
			if (elm.wait === void) {
				elm.wait = 0;
			}
			return func(elm);
		}
		return 0;
	}

	//------------------------------------------------------- Tag Handlers --
    
	function getHandlers()
	{
		return %[ // Dictionary object

		/*
			Tag handlers are pairs of names and corresponding functions.
			Format:
			name : function(elm)
			{
				// function body
			} incontextof this,
			Note: Use "name" => if name is a reserved word.
			incontextof this is required for the function to correctly operate 
			within the context of this class's object.
		*/

	//--------------------------------------- Tag Handlers (Message Operations) --
    parse : function(elm)
    {
        // Special parsing process
        conductor.parseAll();
        return 0;
	} incontextof this,

    voice : function(elm)
    {
        // Ignore
        return 0;
	} incontextof this,

    ch : function(elm)
    {
		if (skipNoDisp) { return 0;	}

		if (lineMode && textWriteEnabled) {
			// Display process
            if (setCurrentMessageLayerVisible(true)) {
                return -3;
            }
        }

        // Display characters
		var acs = actualChSpeed;
		if(updateBeforeCh)
		{
			if(flipStartFlag || acs) { updateBeforeCh--; return -5; } else { updateBeforeCh--; }
		}
		var text = elm.text, repage = void;
		@if (KAGHOOK_PROCESSCH)
		{
			var tmp = %[ text:text ];
			if (callHook("onProcessCh", tmp)) {
				text = tmp.text;
				if (text == "") return 0;
			}
		}
		@endif
		if (textWriteEnabled) {
			if(currentWithBack) current.comp.processCh(text);
			repage = current.processCh(text, chUserMode ? acs : 0);
			if(repage)
			{
				return showPageBreakAndClear();
			}
		}
		if(historyWriteEnabled)
		{
			historyLayer.autoReline() if (repage === false && typeof historyLayer.autoReline == "Object");
			historyLayer.store(text);
		}
		if(autoWCEnabled && skipMode <= SKIP_STOP)
		{
			// Auto-wait
			var ind;
			if((ind = autoWCChars.indexOf(text)) != -1)
			{
				return int(acs * autoWCWaits[ind]);
			}
		}
		return acs * actskipspeed;
	} incontextof this,

    dispname : function(elm)
    {
		if (skipNoDisp) { return 0;	}
		
		// Display process
		if (setCurrentMessageLayerVisible(true)) {
			return -3;
		}

		// Message window clear process
		if (!erAfterPage) {
			tagHandlers.er(%[]);
		}
		
		if (elm !== void) {
            var name = elm.disp !== void ? elm.disp : elm.name;
            if (name !== void) {
                return tagHandlers.ch(%["text" => "【" + elm.name + "】"]);
            }
        }
        return 0;
	} incontextof this,

	graph : function(elm)
	{
		if (skipNoDisp) { return 0;	}

		if (lineMode && textWriteEnabled) {
			// Display process
            if (setCurrentMessageLayerVisible(true)) {
                return -3;
            }
        }

		// Display graphic as character
		var acs = actualChSpeed;
		if(updateBeforeCh)
		{
			if(flipStartFlag || acs) { updateBeforeCh--; return -5; } else { updateBeforeCh--; }
		}
		var text = elm.alt, repage = void;
		if (textWriteEnabled) {
			if(currentWithBack) current.comp.processGraph(elm);
			repage = current.processGraph(elm);
			if(repage)
			{
				return showPageBreakAndClear();
			}
		}
		if(historyWriteEnabled)
		{
			historyLayer.autoReline() if (repage === false && typeof historyLayer.autoReline == "Object");
			historyLayer.store(text, true) if (text !== void);
		}
		return acs * actskipspeed;
	} incontextof this,

	hch : function(elm)
	{
		if (skipNoDisp) { return 0;	}

		// Tategaki-chu-yokogaki (Horizontal text in vertical)
		var acs = actualChSpeed;
		if(updateBeforeCh)
		{
			if(acs) { updateBeforeCh--; return -5; } else { updateBeforeCh--; }
		}
		var text = elm.text;
		var expand = elm.expand !== void && +elm.expand;
		if (textWriteEnabled) {
			if(currentWithBack) current.comp.putHorizonCh(text, expand);
			if(current.putHorizonCh(text, expand))
			{
				return showPageBreakAndClear();
			}
		}
		if(historyWriteEnabled) historyLayer.store(text);
		return acs * actskipspeed;
	} incontextof this,

    linemode : function(elm) {
        setLineMode(elm.mode);
        return 0;
    } incontextof this,

    craftername : function(elm) {
        setCrAfterName(elm.mode);
        return 0;
