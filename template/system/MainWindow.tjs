	//----------------------------------------- Tag Handlers (Special Branching) --

	// Branching occurring in internal tag processing is aggregated here
	next : function(elm)
	{
		if (autoLabelMode) {
			autoLabelCount++;
			storeAutoLabel();
		}
		//dm("next condition:" + elm.eval);
		if (elm.eval == "" || Scripts.eval(elm.eval)) {
			if (elm.exp !== void) {
				Scripts.eval(elm.exp);
			}
			if (elm.storage !== void || elm.target !== void) {
				if (forEachFunctionHook("onNext", elm.storage, elm.target) === void) {
					// Perform KAG transition if branching was not handled by plugin
					checkSkipOnNextLabel = true; // Check auto-skip for read labels at destination
					process(elm.storage, elm.target);
				}
			}
		}
		return 0;
	} incontextof this,

    // Equivalent to next when storage is specified, but not intercepted by plugins. Equivalent to gotostart if nothing specified.
	exit : function(elm)
	{
