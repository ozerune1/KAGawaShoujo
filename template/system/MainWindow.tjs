		}

	}



	var flipStartFlag = false;

	

	function flipStart() {

		if (!flipStartFlag) {

			System.addContinuousHandler(onFlipTimerInterval);

			flipStartFlag = true;

		}

	}



	function flipStop() {

		if (flipStartFlag) {

			System.removeContinuousHandler(onFlipTimerInterval);

			flipStartFlag = false;

		}

	}

	

