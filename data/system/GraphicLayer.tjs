class CharacterLayer extends GraphicLayerEx

{

	// Foreground layer

	var autoHide = false; // Whether it can be hidden along with the message layer

	var invisibleByUser = false; // Temporarily invisible by user

    var visibleBeforeUserInvisible  = false;

    var level; // For display level correction



	function CharacterLayer(win, par, name, id, level)

	{

        super.GraphicLayerEx(win, par, name, id);

		freeImage();

		defaultType = type = ltCoverRect;

		hitType = htMask;

