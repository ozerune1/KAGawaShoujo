        this.level = level;

	}



	function finalize()

	{

		super.finalize(...);

	}



	function onHitTest(x, y, hit)

	{

		// onHitTest override

		if(!hit || provinceActions === void)

		{

			// If hit==false or area action is not defined

			super.onHitTest(x, y, false);

		}

		else

		{

			// If hit==true and area action is defined

			super.onHitTest(x, y, !window.messageLayerHiding);

		}

		return;

	}



	function assign(src)

	{

		// assign override

		super.assign(src);

		assignVisibleState(src);

