			//   Nothing needs to be done, but their child layers will automatically be hidden on finish.

		}

		else

		{

			// - Message layer and foreground layer transition with src (children=true)

			//   Exchange important information with transition source. If exchange=false,

			//   also copy transition source info to transition destination. However, during this copy,

			//   window visibility information is not copied.

			super.assign(src);

