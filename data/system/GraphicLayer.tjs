		super.onMouseDown(...);

		if(button == mbLeft)

			processProvince(x, y);

		else if(button == mbRight)

			window.onPrimaryRightClick();

			// Right button calls window.onPrimaryRightClick()

	}



	function store()

	{

		// store override

		var dic = super.store();

        dic.autoHide = autoHide;

