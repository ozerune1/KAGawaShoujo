				invisibleByUser = true; // Temporarily invisible by user

				visible = false;

			}

			else

			{

				invisibleByUser = false; // Visible

				visible = visibleBeforeUserInvisible;

			}

		}

	}



	function onMouseDown(x, y, button)

	{

