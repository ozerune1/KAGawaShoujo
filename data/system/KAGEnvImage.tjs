			names.assign(act);
			if (act.module !== void || act.moduleName !== void) {
				// Old style
				for (var i=0; i<names.count; i+= 2) {
					var name = names[i];
					var elm  = names[i+1];
					action[name] = elm;
				}
				if (time !== void) {
					action.time = time;
				}
				// Copy parameters
				if (over !== void) {
					foreach(over, function(name, value, over, action) {
						if (actionParam[name] !== void && value !== void) {
							//dm("Parameter override:" + name + ":" + value);
							action[name] = value;
						}
					}, action);
				}
			} else {
				// New style
				for (var i=0; i<names.count; i+= 2) {
					var name = names[i];
					var elm  = names[i+1];
					if (elm instanceof "Dictionary") {
						// If dictionary, clone and pass it
