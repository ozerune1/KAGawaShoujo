	function copyActionInfo(act, time, over) {
		if (act instanceof "Array") {
			// Array action
			var arrayAction = [];
			for (var i=0;i<act.count;i++) {
				var i = act[i];
				if (typeof i == "String") {
					// Recursively reference if string
