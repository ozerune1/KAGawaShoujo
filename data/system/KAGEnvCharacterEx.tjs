			}
			return updateFlag;
		}
		
		// For eye blinking processing
		switch (eyestate) {
		case 0: // Default
			if (eyeLevel !== void) {
				eyeLevel = void;
				updateFlag = true;
			}
			break;
		case 1: // Open
			if (eyeLevel !== 2) {
				eyeLevel = 2;
				updateFlag = true;
			}
			break;
		case 2: // Closed
