					eyeLevel = 2;
					updateFlag = true;
				} else {
					eyestate = 1;
					env.trigger(name + "_eyeopen");
				}
				break;
			}
			break;
		case 5: // Transition to closed state
			switch (eyeLevel) {
			case 2:
				eyeLevel = 1;
				updateFlag = true;
				break;
			default:
				if (eyeLevel !== 0) {
					eyeLevel = 0;
					updateFlag = true;
