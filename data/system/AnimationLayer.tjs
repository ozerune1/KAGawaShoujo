}





// Handlers used when restoring reconstructible information
// during save file loading, such as pimage and ptext tags.
// (Defines the tag name and corresponding handler)
AnimationLayer.Anim_reconstructHandlers =
	%[
		pimage	:	AnimationLayer.loadPartialImage,
		ptext	:	AnimationLayer.drawReconstructibleText
	];





class ClickGlyphLayer extends KAGLayer
{
	var copyMethods = [
		/* AnimationLayer methods */
		"clearImage",
		"freeImage",
		"initAnim",
		"termAnim",
		"clearAnim",
		"loadAnimInfo",
		"startAnim",
		"stopAnim",
		"canWaitAnimStop",
		//"loadImages",						// Special handling
		//"addPartialImageInfo",			// Disabled
		//"loadPartialImage",				// 〃
		//"drawReconstructibleText",		// 〃
		//"applyColorCorrection",			// 〃
		"setInterrupted",
		//"assign",							// Not used (⇒KAGWindow#lineBreak/pageBreak)
		//"store",							// 〃
		//"restore",						// 〃

		/* tag handlers */
		"load",
		"loadcell",
		"copy",
		"s",
		"loop",
		"home",
		"clip",
		"wait",
		"eval",
		"option",
		];

	// Stub methods for disabled functionality
	function addPartialImageInfo() {}
	function loadPartialImage() {}
	function drawReconstructibleText() {}
	function applyColorCorrection() {}
	function assign(src) { super.assignImages(src); }

	// superclass hack (⇒AnimationLayer#superLoadImages)
	function superLoadImages() { return super.loadImages(...); }

	// Click waiting glyph layer
	var loadedImage; // Currently loaded image
	var loadedKey; // Currently loaded key
	var restartOnReload = false; // Whether to restart animation from beginning on reload

	function ClickGlyphLayer(win, par)
	{
		// Constructor
		super.KAGLayer(win, par);
		hitType = htMask;
		hitThreshold = 256; // Fully transparent to mouse messages

		// Copy methods
		var anim = global.AnimationLayer;
		for (var i = copyMethods.count-1; i >= 0; i--) {
			var mn = copyMethods[i];
			this[mn] = (anim[mn] incontextof this) if (mn != "");
		}
		this.animLoadImages = (anim.loadImages incontextof this);

		// Initialize
		initAnim();
	}

	function finalize()
	{
		termAnim();
		// finalize()
		super.finalize(...);
	}

	function loadImages(storage, key)
	{
		// loadImage override
		if(loadedImage !== storage || loadedKey !== key)
		{
			animLoadImages(%[storage : storage, key : key]);
			loadedImage = storage;
			loadedKey = key;
		}
		else
		{
			startAnim(%[ seg:0, target:"" ]) if (restartOnReload && Anim_storageName != '');
		}
	}

	property type {
		getter() { return super.type; }
		setter(v) { super.type = v === void ? ltAlpha : v; }
	}
	
	property visible
	{
		// visible override
		getter()
		{
			return super.visible;
		}
		setter(x)
		{
			super.visible = x;
			// Stop operation when invisible
			setInterrupted(!x);
		}
	}
}