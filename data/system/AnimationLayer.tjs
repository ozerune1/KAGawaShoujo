	function restore(dic)
	{
		// Restore information from dic
        try {
            loadImages(dic.loadParams);
        } catch (e) {
            dm("Failed to load image during restore: " + dic.loadParams);
        } 
		if(dic.loadParams !== void)
		{
			// Restore animation segment info
			var dicsegments = dic.segments;
			if(dicsegments !== void)
			{
				var dicsegmentscount = dicsegments.count;
