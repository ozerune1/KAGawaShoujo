		// Horizontal flip
		flipLR() if (lp.fliplr !== void && +lp.fliplr);

		return -4; // Event processing once
	}

	/* Tag handler */ function loadcell(elm)
	{
		// Load cell image into cell layer

		// Secure cell layer
		if(Anim_cellLayer === void)
			Anim_cellLayer = new global.KAGLayer(window, this); // Create layer

		// Determine color key
		var key;
		if(elm.key !== void)
		{
			// key specified
			key = elm.key;
		}
		else
		{
			// key not specified
			key = Anim_loadParams.key; // Use key from loadParams
		}

		// Determine storage name
		var storage;
		if(elm.storage !== void)
		{
			// storage specified
			storage = elm.storage;
		}
		else
		{
			// storage not specified
			storage = Storages.chopStorageExt(Anim_loadParams.storage) + "_a";
				// Use storage from loadParams
		}

		// Load image into cell layer
		Anim_cellLayer.loadImages(storage, key);

		// Apply color correction to cell layer
		applyColorCorrection(Anim_cellLayer, Anim_loadParams);

		// Flip
		if(Anim_loadParams.flipud !== void && +Anim_loadParams.flipud)
		{
			// Vertical flip
			Anim_cellLayer.flipUD();
		}
		if(Anim_loadParams.fliplr !== void && +Anim_loadParams.fliplr)
