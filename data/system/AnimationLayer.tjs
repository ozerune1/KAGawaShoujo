	/* Tag handler */ function load(elm)
	{
		// Load image
		var lp = Anim_loadParams !== void ? Anim_loadParams : %[];
		var key = (elm.key !== void) ? elm.key : lp.key;
		var storage = elm.storage;
		var otype = type;
		superLoadImages(storage, key, elm);
		type = otype;
		applyColorCorrection(this, lp);
